@model RenovatorApp.Web.ViewModels.CalendarIndexViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Calendar";
    var previousMonth = Model.DisplayMonth.AddMonths(-1);
    var nextMonth = Model.DisplayMonth.AddMonths(1);
}

<div class="calendar-page">
    <div class="calendar-topbar">
        <a class="btn btn-secondary" asp-controller="Home" asp-action="Index">Back</a>
        <div class="calendar-title-group">
            <span class="calendar-month-title">@Model.DisplayMonth.ToString("MMM", CultureInfo.CurrentCulture)</span>
            <span class="calendar-year-title">@Model.DisplayMonth.Year</span>
        </div>
        <div class="calendar-nav-buttons">
            <a class="btn btn-outline-secondary"
               asp-action="Index"
               asp-route-year="@previousMonth.Year"
               asp-route-month="@previousMonth.Month"
               asp-route-selectedDate="@ClampSelectedDate(previousMonth).ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)"
               aria-label="Previous month">&lt;</a>
            <a class="btn btn-outline-secondary"
               asp-action="Index"
               asp-route-year="@nextMonth.Year"
               asp-route-month="@nextMonth.Month"
               asp-route-selectedDate="@ClampSelectedDate(nextMonth).ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)"
               aria-label="Next month">&gt;</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success mb-0">@Model.StatusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger mb-0">@Model.ErrorMessage</div>
    }

    <form class="calendar-picker-card calendar-web-picker" method="get" asp-action="Index">
        <input type="hidden" name="selectedDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)" />
        <div>
            <label class="form-label" for="calendar-month">Month</label>
            <select class="form-select calendar-month-select" id="calendar-month" name="month">
                @for (var month = 1; month <= 12; month++)
                {
                    <option value="@month" selected="@(month == Model.DisplayMonth.Month)">
                        @CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(month)
                    </option>
                }
            </select>
        </div>
        <div>
            <label class="form-label" for="calendar-year">Year</label>
            <select class="form-select calendar-year-select" id="calendar-year" name="year">
                @for (var year = 2025; year <= 2050; year++)
                {
                    <option value="@year" selected="@(year == Model.DisplayMonth.Year)">@year</option>
                }
            </select>
        </div>
        <button class="btn btn-primary" type="submit">Go</button>
    </form>

    <section class="calendar-shell" aria-label="Calendar month">
        <div class="calendar-weekdays">
            @foreach (var weekday in new[] { "S", "M", "T", "W", "T", "F", "S" })
            {
                <span>@weekday</span>
            }
        </div>

        <div class="calendar-grid">
            @foreach (var day in Model.Days)
            {
                <a class="@GetDayClass(day.Date)"
                   asp-action="Index"
                   asp-route-year="@day.Date.Year"
                   asp-route-month="@day.Date.Month"
                   asp-route-selectedDate="@day.Date.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)"
                   asp-route-showDay="true">
                    <span class="calendar-day-number">@day.Date.Day</span>
                    <span class="calendar-day-events">
                        @foreach (var calendarEvent in day.Events.Take(3))
                        {
                            <span>@calendarEvent.Title</span>
                        }
                    </span>
                </a>
            }
        </div>
    </section>

    <div class="calendar-workspace">
        <section class="calendar-day-panel">
            <div class="calendar-panel-header">
                <div>
                    <h2>@Model.SelectedDate.ToString("dddd, MMM d", CultureInfo.CurrentCulture)</h2>
                    <p class="text-muted">@Model.SelectedDayEvents.Count event@(Model.SelectedDayEvents.Count == 1 ? string.Empty : "s")</p>
                </div>
                <a class="btn btn-primary"
                   asp-action="Index"
                   asp-route-year="@Model.DisplayMonth.Year"
                   asp-route-month="@Model.DisplayMonth.Month"
                   asp-route-selectedDate="@Model.SelectedDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)"
                   asp-route-showEditor="true">
                    Add Event
                </a>
            </div>

            <div class="calendar-day-event-list">
                @if (Model.SelectedDayEvents.Count == 0)
                {
                    <p class="text-muted mb-0">No calendar events for this day.</p>
                }
                else
                {
                    @foreach (var calendarEvent in Model.SelectedDayEvents)
                    {
                        <a class="calendar-day-event-row"
                           asp-action="Index"
                           asp-route-year="@Model.DisplayMonth.Year"
                           asp-route-month="@Model.DisplayMonth.Month"
                           asp-route-selectedDate="@calendarEvent.Date.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)"
                           asp-route-editId="@calendarEvent.Id">
                            <span class="calendar-day-event-time">@FormatEventTime(calendarEvent)</span>
                            <span class="calendar-day-event-created-by">Added by @calendarEvent.CreatedByName</span>
                            <span class="calendar-day-event-title">
                                @calendarEvent.Title
                                @if (calendarEvent.IsPrivate)
                                {
                                    <span class="badge text-bg-secondary ms-1">Private</span>
                                }
                            </span>
                            @if (!string.IsNullOrWhiteSpace(calendarEvent.Notes))
                            {
                                <span class="calendar-day-event-notes">@calendarEvent.Notes</span>
                            }
                        </a>
                    }
                }
            </div>
        </section>

        @if (Model.EventForm is not null)
        {
            <section class="calendar-event-editor">
                <div class="calendar-panel-header">
                    <div>
                        <h2>@(Model.EventForm.Id.HasValue ? "Edit Event" : "Add Event")</h2>
                        <p class="text-muted">@Model.EventForm.Date.ToString("MMM d, yyyy", CultureInfo.CurrentCulture)</p>
                    </div>
                </div>

                <form class="calendar-event-form" asp-action="Save" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="EventForm.Id" name="Id" />
                    <input type="hidden" asp-for="EventForm.Year" name="Year" />
                    <input type="hidden" asp-for="EventForm.Month" name="Month" />

                    <div>
                        <label class="form-label" for="event-date">Date</label>
                        <input class="form-control" id="event-date" type="date" name="Date" value="@Model.EventForm.Date.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)" />
                    </div>

                    <div>
                        <p class="calendar-event-created-by">Added by @Model.EventForm.CreatedByName</p>
                        <label class="form-label" for="event-title">Title</label>
                        <input class="form-control" id="event-title" name="Title" value="@Model.EventForm.Title" required />
                    </div>

                    <label class="calendar-toggle-row">
                        <input class="form-check-input" id="event-all-day" type="checkbox" name="AllDay" value="true" checked="@Model.EventForm.AllDay" />
                        <input type="hidden" name="AllDay" value="false" />
                        <span>All Day</span>
                    </label>

                    <div class="calendar-time-grid" id="calendar-time-fields">
                        <div>
                            <label class="form-label" for="event-start-time">Start Time</label>
                            <input class="form-control" id="event-start-time" type="time" name="StartTime" value="@Model.EventForm.StartTime" />
                        </div>
                        <div>
                            <label class="form-label" for="event-end-time">End Time</label>
                            <input class="form-control" id="event-end-time" type="time" name="EndTime" value="@Model.EventForm.EndTime" />
                        </div>
                    </div>

                    <div>
                        <p class="calendar-field-label">Alert</p>
                        <div class="calendar-alert-picker">
                            <input type="hidden" name="AlertOffsets" value="" />
                            @foreach (var alert in AlertOptions)
                            {
                                <label>
                                    <input type="checkbox" name="AlertOffsets" value="@alert.Value" checked="@Model.EventForm.AlertOffsets.Contains(alert.Value)" />
                                    <span>@alert.Label</span>
                                </label>
                            }
                        </div>
                    </div>

                    <div>
                        <label class="form-label" for="event-notes">Notes</label>
                        <textarea class="form-control calendar-notes-input" id="event-notes" name="Notes" rows="3">@Model.EventForm.Notes</textarea>
                    </div>

                    <label class="calendar-private-row">
                        <input class="form-check-input" type="checkbox" name="IsPrivate" value="true" checked="@Model.EventForm.IsPrivate" />
                        <input type="hidden" name="IsPrivate" value="false" />
                        <span>Private</span>
                    </label>

                    <div class="calendar-event-actions @(Model.EventForm.Id.HasValue ? "calendar-event-actions-editing" : null)">
                        @if (Model.EventForm.Id.HasValue)
                        {
                            <button class="btn btn-danger"
                                    type="submit"
                                    form="delete-calendar-event-form"
                                    onclick="return confirm('Delete this calendar event?');">
                                Delete
                            </button>
                        }
                        <div class="calendar-event-save-actions">
                            <a class="btn btn-secondary"
                               asp-action="Index"
                               asp-route-year="@Model.DisplayMonth.Year"
                               asp-route-month="@Model.DisplayMonth.Month"
                               asp-route-selectedDate="@Model.SelectedDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)">
                                Cancel
                            </a>
                            <button class="btn btn-primary" type="submit">Save</button>
                        </div>
                    </div>
                </form>

                @if (Model.EventForm.Id.HasValue)
                {
                    <form id="delete-calendar-event-form" asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.EventForm.Id" />
                        <input type="hidden" name="year" value="@Model.DisplayMonth.Year" />
                        <input type="hidden" name="month" value="@Model.DisplayMonth.Month" />
                        <input type="hidden" name="selectedDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)" />
                    </form>
                }
            </section>
        }
    </div>
</div>

@if (Model.ShowDayDialog)
{
    <div class="modal fade" id="calendar-day-modal" tabindex="-1" aria-labelledby="calendar-day-modal-title" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content calendar-modal-content">
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="calendar-day-modal-title">@Model.SelectedDate.Day @Model.SelectedDate.ToString("dddd", CultureInfo.CurrentCulture)</h2>
                    <a class="btn-close"
                       asp-action="Index"
                       asp-route-year="@Model.DisplayMonth.Year"
                       asp-route-month="@Model.DisplayMonth.Month"
                       asp-route-selectedDate="@Model.SelectedDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)"
                       aria-label="Close"></a>
                </div>
                <div class="modal-body">
                    <div class="calendar-day-event-list">
                        @if (Model.SelectedDayEvents.Count == 0)
                        {
                            <p class="text-muted mb-0">No calendar events for this day.</p>
                        }
                        else
                        {
                            @foreach (var calendarEvent in Model.SelectedDayEvents)
                            {
                                <a class="calendar-day-event-row"
                                   asp-action="Index"
                                   asp-route-year="@Model.DisplayMonth.Year"
                                   asp-route-month="@Model.DisplayMonth.Month"
                                    asp-route-selectedDate="@calendarEvent.Date.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)"
                                   asp-route-editId="@calendarEvent.Id">
                                    <span class="calendar-day-event-time">@FormatEventTime(calendarEvent)</span>
                                    <span class="calendar-day-event-created-by">Added by @calendarEvent.CreatedByName</span>
                                    <span class="calendar-day-event-title">@calendarEvent.Title</span>
                                    @if (!string.IsNullOrWhiteSpace(calendarEvent.Notes))
                                    {
                                        <span class="calendar-day-event-notes">@calendarEvent.Notes</span>
                                    }
                                </a>
                            }
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <a class="btn btn-primary"
                       asp-action="Index"
                       asp-route-year="@Model.DisplayMonth.Year"
                       asp-route-month="@Model.DisplayMonth.Month"
                       asp-route-selectedDate="@Model.SelectedDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)"
                       asp-route-showEditor="true">
                        Add on @Model.SelectedDate.ToString("MMM d", CultureInfo.CurrentCulture)
                    </a>
                    <a class="btn btn-secondary"
                       asp-action="Index"
                       asp-route-year="@Model.DisplayMonth.Year"
                       asp-route-month="@Model.DisplayMonth.Month"
                       asp-route-selectedDate="@Model.SelectedDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)">
                        Close
                    </a>
                </div>
            </div>
        </div>
    </div>
}

@if (Model.EventForm is not null)
{
    <div class="modal fade" id="calendar-event-modal" tabindex="-1" aria-labelledby="calendar-event-modal-title" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content calendar-modal-content">
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="calendar-event-modal-title">@(Model.EventForm.Id.HasValue ? "Edit Event" : "Add Event")</h2>
                    <a class="btn-close"
                       asp-action="Index"
                       asp-route-year="@Model.DisplayMonth.Year"
                       asp-route-month="@Model.DisplayMonth.Month"
                       asp-route-selectedDate="@Model.SelectedDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)"
                       aria-label="Close"></a>
                </div>
                <div class="modal-body">
                    <form class="calendar-event-form" id="calendar-event-modal-form" asp-action="Save" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="EventForm.Id" name="Id" />
                        <input type="hidden" asp-for="EventForm.Year" name="Year" />
                        <input type="hidden" asp-for="EventForm.Month" name="Month" />

                        <div>
                            <label class="form-label" for="modal-event-date">Date</label>
                            <input class="form-control" id="modal-event-date" type="date" name="Date" value="@Model.EventForm.Date.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)" />
                        </div>

                        <div>
                            <p class="calendar-event-created-by">Added by @Model.EventForm.CreatedByName</p>
                            <label class="form-label" for="modal-event-title">Title</label>
                            <input class="form-control" id="modal-event-title" name="Title" value="@Model.EventForm.Title" required />
                        </div>

                        <label class="calendar-toggle-row">
                            <input class="form-check-input event-all-day-toggle" type="checkbox" name="AllDay" value="true" checked="@Model.EventForm.AllDay" />
                            <input type="hidden" name="AllDay" value="false" />
                            <span>All Day</span>
                        </label>

                        <div class="calendar-time-grid calendar-time-fields">
                            <div>
                                <label class="form-label" for="modal-event-start-time">Start Time</label>
                                <input class="form-control" id="modal-event-start-time" type="time" name="StartTime" value="@Model.EventForm.StartTime" />
                            </div>
                            <div>
                                <label class="form-label" for="modal-event-end-time">End Time</label>
                                <input class="form-control" id="modal-event-end-time" type="time" name="EndTime" value="@Model.EventForm.EndTime" />
                            </div>
                        </div>

                        <div>
                            <p class="calendar-field-label">Alert</p>
                            <div class="calendar-alert-picker">
                                <input type="hidden" name="AlertOffsets" value="" />
                                @foreach (var alert in AlertOptions)
                                {
                                    <label>
                                        <input type="checkbox" name="AlertOffsets" value="@alert.Value" checked="@Model.EventForm.AlertOffsets.Contains(alert.Value)" />
                                        <span>@alert.Label</span>
                                    </label>
                                }
                            </div>
                        </div>

                        <div>
                            <label class="form-label" for="modal-event-notes">Notes</label>
                            <textarea class="form-control calendar-notes-input" id="modal-event-notes" name="Notes" rows="3">@Model.EventForm.Notes</textarea>
                        </div>

                        <label class="calendar-private-row">
                            <input class="form-check-input" type="checkbox" name="IsPrivate" value="true" checked="@Model.EventForm.IsPrivate" />
                            <input type="hidden" name="IsPrivate" value="false" />
                            <span>Private</span>
                        </label>
                    </form>

                    @if (Model.EventForm.Id.HasValue)
                    {
                        <form id="delete-calendar-event-modal-form" asp-action="Delete" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.EventForm.Id" />
                            <input type="hidden" name="year" value="@Model.DisplayMonth.Year" />
                            <input type="hidden" name="month" value="@Model.DisplayMonth.Month" />
                            <input type="hidden" name="selectedDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)" />
                        </form>
                    }
                </div>
                <div class="modal-footer calendar-event-actions @(Model.EventForm.Id.HasValue ? "calendar-event-actions-editing" : null)">
                    @if (Model.EventForm.Id.HasValue)
                    {
                        <button class="btn btn-danger"
                                type="submit"
                                form="delete-calendar-event-modal-form"
                                onclick="return confirm('Delete this calendar event?');">
                            Delete
                        </button>
                    }
                    <div class="calendar-event-save-actions">
                        <a class="btn btn-secondary"
                           asp-action="Index"
                           asp-route-year="@Model.DisplayMonth.Year"
                           asp-route-month="@Model.DisplayMonth.Month"
                           asp-route-selectedDate="@Model.SelectedDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)">
                            Cancel
                        </a>
                        <button class="btn btn-primary" type="submit" form="calendar-event-modal-form">Save</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        (() => {
            document.querySelectorAll('.event-all-day-toggle').forEach((allDay) => {
                const form = allDay.closest('form');
                const timeFields = form?.querySelector('.calendar-time-fields');

                if (!timeFields) {
                    return;
                }

                const updateTimeVisibility = () => {
                    timeFields.hidden = allDay.checked;
                };

                allDay.addEventListener('change', updateTimeVisibility);
                updateTimeVisibility();
            });

            const modalId = '@(!string.IsNullOrWhiteSpace(Model.ErrorMessage) ? string.Empty : Model.EventForm is not null ? "calendar-event-modal" : Model.ShowDayDialog ? "calendar-day-modal" : string.Empty)';
            if (modalId) {
                const modalElement = document.getElementById(modalId);
                if (modalElement) {
                    bootstrap.Modal.getOrCreateInstance(modalElement).show();
                }
            }
        })();
    </script>
}

@functions {
    private static readonly (string Value, string Label)[] AlertOptions =
    [
        ("0", "At time of event"),
        ("-10m", "10 mins before"),
        ("-1h", "1 hour before"),
        ("-1d", "1 day before")
    ];

    private DateTime ClampSelectedDate(DateTime displayMonth)
    {
        var day = Math.Min(Model.SelectedDate.Day, DateTime.DaysInMonth(displayMonth.Year, displayMonth.Month));
        return new DateTime(displayMonth.Year, displayMonth.Month, day);
    }

    private string GetDayClass(DateTime date)
    {
        var classes = new List<string> { "calendar-day-cell" };

        if (date.Date == Model.SelectedDate.Date)
        {
            classes.Add("calendar-day-selected");
        }

        if (date.Month != Model.DisplayMonth.Month)
        {
            classes.Add("calendar-day-outside");
        }

        if (date.Date == DateTime.Today)
        {
            classes.Add("calendar-day-today");
        }

        return string.Join(" ", classes);
    }

    private static string FormatEventTime(RenovatorApp.Web.ViewModels.CalendarEventRowViewModel calendarEvent)
    {
        if (calendarEvent.AllDay)
        {
            return "All day";
        }

        return $"{FormatTimeDisplay(calendarEvent.StartTime)} - {FormatTimeDisplay(calendarEvent.EndTime)}";
    }

    private static string FormatTimeDisplay(TimeSpan value)
    {
        return DateTime.Today.Add(value).ToString("h:mm tt", CultureInfo.CurrentCulture);
    }
}
