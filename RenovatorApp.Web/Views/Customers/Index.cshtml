@model RenovatorApp.Web.ViewModels.CustomersIndexViewModel
@{
    ViewData["Title"] = "Customers";
    var previousPage = Math.Max(1, Model.Page - 1);
    var nextPage = Math.Min(Model.TotalPages, Model.Page + 1);
}

<div class="page-header-row">
    <div>
        <h1>Customers</h1>
        <p class="text-muted">@Model.TotalCustomers customer@(Model.TotalCustomers == 1 ? string.Empty : "s")</p>
    </div>
    <div class="customer-sync-actions">
        <button class="btn btn-primary"
                id="newCustomerButton"
                type="button"
                data-bs-toggle="modal"
                data-bs-target="#newCustomerModal">
            New Customer
        </button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info" role="alert">@Model.StatusMessage</div>
}

<form class="customer-search-row customer-search-row-narrow" id="customerSearchForm" method="get">
    <input class="form-control"
           id="customerSearch"
           name="search"
           placeholder="search customers"
           type="search"
           value="@Model.Search" />
    <button class="btn btn-outline-secondary" id="clearCustomerSearch" type="button">Clear</button>
    <div class="form-check customer-show-inactive">
        <input class="form-check-input"
               id="showInactive"
               name="showInactive"
               type="checkbox"
               value="true"
               @(Model.ShowInactive ? "checked" : string.Empty) />
        <label class="form-check-label" for="showInactive">Show Inactive</label>
    </div>
    <input id="customerPage" name="page" type="hidden" value="@Model.Page" />
</form>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th scope="col">Display Name</th>
                <th scope="col">Company</th>
                <th scope="col">Contact</th>
                <th scope="col">Email</th>
                <th scope="col">Phone</th>
                <th scope="col">Active</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Customers.Count == 0)
            {
                <tr>
                    <td class="text-muted" colspan="6">No customers found.</td>
                </tr>
            }
            else
            {
                @foreach (var customer in Model.Customers)
                {
                    <tr class="clickable-table-row"
                        data-href="@Url.Action("Details", "Customers", new { id = customer.CustomerId })"
                        tabindex="0"
                        aria-label="Open @customer.DisplayName"
                        title="QBID: @customer.QuickBooksCustomerId&#10;CID: @customer.CustomerId">
                        <td><strong>@customer.DisplayName</strong></td>
                        <td>@customer.CompanyName</td>
                        <td>@customer.ContactName</td>
                        <td>@customer.Email</td>
                        <td>@customer.Phone</td>
                        <td>@customer.Active</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<div class="d-flex align-items-center justify-content-between gap-3">
    <div class="btn-group" role="group" aria-label="Customer pages">
        <a class="btn btn-outline-secondary @(Model.Page == 1 ? "disabled" : string.Empty)"
           asp-controller="Customers"
           asp-action="Index"
           asp-route-search="@Model.Search"
           asp-route-showInactive="@Model.ShowInactive"
           asp-route-page="@previousPage">
            Previous
        </a>
        <a class="btn btn-outline-secondary @(Model.Page == Model.TotalPages ? "disabled" : string.Empty)"
           asp-controller="Customers"
           asp-action="Index"
           asp-route-search="@Model.Search"
           asp-route-showInactive="@Model.ShowInactive"
           asp-route-page="@nextPage">
            Next
        </a>
    </div>
    <span class="text-muted">Page @Model.Page of @Model.TotalPages</span>
</div>

<div class="modal fade" id="newCustomerModal" tabindex="-1" aria-label="New Customer" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 80vw;">
        <div class="modal-content" style="height: 80vh;">
            <div class="modal-body p-0" style="height: 100%;">
                <iframe id="newCustomerFrame"
                        title="New Customer"
                        src="@Url.Action("New", "Customers", new { embedded = true })"
                        style="border: 0; display: block; height: 100%; width: 100%;"></iframe>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const searchForm = document.getElementById('customerSearchForm');
        const searchInput = document.getElementById('customerSearch');
        const pageInput = document.getElementById('customerPage');
        const clearSearchButton = document.getElementById('clearCustomerSearch');
        const showInactiveInput = document.getElementById('showInactive');
        const newCustomerModal = document.getElementById('newCustomerModal');
        const newCustomerFrame = document.getElementById('newCustomerFrame');
        const newCustomerUrl = '@Url.Action("New", "Customers", new { embedded = true })';
        let refreshCustomersOnModalClose = false;
        let searchTimer;

        document.querySelectorAll('.clickable-table-row').forEach((row) => {
            const navigate = () => {
                const href = row.getAttribute('data-href');
                if (href) {
                    window.location.href = href;
                }
            };

            row.addEventListener('click', navigate);
            row.addEventListener('keydown', (event) => {
                if (event.key === 'Enter' || event.key === ' ') {
                    event.preventDefault();
                    navigate();
                }
            });
        });

        searchInput?.addEventListener('input', () => {
            window.clearTimeout(searchTimer);
            const value = (searchInput.value || '').trim();
            searchTimer = window.setTimeout(() => {
                if (value.length === 0 || value.length >= 2) {
                    pageInput.value = '1';
                    searchForm.submit();
                }
            }, 350);
        });

        clearSearchButton?.addEventListener('click', () => {
            searchInput.value = '';
            pageInput.value = '1';
            searchForm.submit();
        });

        showInactiveInput?.addEventListener('change', () => {
            pageInput.value = '1';
            searchForm.submit();
        });

        newCustomerModal?.addEventListener('show.bs.modal', () => {
            refreshCustomersOnModalClose = false;
            if (newCustomerFrame) {
                newCustomerFrame.src = newCustomerUrl;
            }
        });

        newCustomerModal?.addEventListener('hidden.bs.modal', () => {
            if (refreshCustomersOnModalClose) {
                window.location.reload();
            }
        });

        window.addEventListener('message', event => {
            if (event.data?.type === 'customerSaved') {
                refreshCustomersOnModalClose = true;
                bootstrap.Modal.getOrCreateInstance(newCustomerModal).hide();
            }

            if (event.data?.type === 'customerModalClose') {
                bootstrap.Modal.getOrCreateInstance(newCustomerModal).hide();
            }
        });
    </script>
}
