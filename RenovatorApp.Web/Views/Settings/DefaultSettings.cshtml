@model RenovatorApp.Web.ViewModels.DefaultSettingsViewModel

@{
    ViewData["Title"] = "Default Settings";
}

<div class="page-header-row">
    <div>
        <h1>Default Settings</h1>
        <p class="text-muted">Manage application default values.</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success" role="status">@Model.StatusMessage</div>
}

<form asp-controller="Settings" asp-action="DefaultSettings" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <section class="detail-section">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label class="form-label" asp-for="DefaultState">Default State</label>
            <select class="form-select" asp-for="DefaultState" style="max-width: 28rem;">
                <option value="">Choose a state</option>
                @foreach (var state in Model.States)
                {
                    <option value="@state.Abbreviation">@state.Name</option>
                }
            </select>
            <span class="text-danger" asp-validation-for="DefaultState"></span>
        </div>

        <div class="form-check mb-3">
            <input class="form-check-input" asp-for="ShareCalendarEventsAcrossCompany" />
            <label class="form-check-label" asp-for="ShareCalendarEventsAcrossCompany">
                Share calendar events across company
            </label>
        </div>

        <div class="mb-3">
            <label class="form-label" asp-for="CompanyIconUpload">Company Application Icon</label>
            <div class="d-flex align-items-center gap-3 mb-2">
                <img class="company-icon-preview"
                     src="@(string.IsNullOrWhiteSpace(Model.CompanyIconUrl) ? Url.Content("~/images/AppIconWeb.png") : Url.Content(Model.CompanyIconUrl))"
                     alt="Current application icon" />
                <span class="text-muted">Shown in the main header for users in this company.</span>
            </div>
            <input class="form-control" asp-for="CompanyIconUpload" type="file" accept=".png,.jpg,.jpeg,.gif,.webp,image/png,image/jpeg,image/gif,image/webp" style="max-width: 28rem;" />
            <span class="text-danger" asp-validation-for="CompanyIconUpload"></span>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary" type="submit">Save</button>
            <a class="btn btn-secondary" asp-controller="Settings" asp-action="Index">Cancel</a>
        </div>
    </section>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
