@model RenovatorApp.Web.ViewModels.InspectionAreasViewModel

@{
    ViewData["Title"] = "Inspection Areas";
    var previousPage = Math.Max(1, Model.Page - 1);
    var nextPage = Math.Min(Model.TotalPages, Model.Page + 1);
}

<div class="page-header-row">
    <div>
        <h1>Inspection Areas</h1>
        <p class="text-muted">@Model.TotalInspectionAreas inspection area@(Model.TotalInspectionAreas == 1 ? string.Empty : "s")</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#addInspectionAreaModal">
            New Area
        </button>
        <a class="btn btn-secondary" asp-controller="Settings" asp-action="Index">Close</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert @Model.StatusClass" role="alert">@Model.StatusMessage</div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th scope="col">Name</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.InspectionAreas.Count == 0)
            {
                <tr>
                    <td class="text-muted">No inspection areas found.</td>
                </tr>
            }
            else
            {
                @foreach (var inspectionArea in Model.InspectionAreas)
                {
                    <tr class="clickable-table-row"
                        tabindex="0"
                        data-area-id="@inspectionArea.InspectionAreaTypeId"
                        data-area-name="@inspectionArea.Name">
                        <td>@inspectionArea.Name</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<div class="modal fade" id="addInspectionAreaModal" tabindex="-1" aria-labelledby="addInspectionAreaModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-controller="Settings" asp-action="AddInspectionArea" method="post" id="addInspectionAreaForm">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="addInspectionAreaModalLabel">Add new Inspection Area</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label" for="inspectionAreaName">Name</label>
                    <input class="form-control" id="inspectionAreaName" name="Name" />
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editInspectionAreaModal" tabindex="-1" aria-labelledby="editInspectionAreaModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" id="editInspectionAreaForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editInspectionAreaId" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="editInspectionAreaModalLabel">Edit Area</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label" for="editInspectionAreaName">Name</label>
                    <input class="form-control" id="editInspectionAreaName" name="Name" />
                </div>
                <div class="modal-footer justify-content-between">
                    <button class="btn btn-danger" type="button" id="deleteInspectionAreaButton">Delete</button>
                    <div class="d-flex gap-2">
                        <button class="btn btn-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                        <button class="btn btn-primary" type="submit">Save</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="inspectionAreaValidationModal" tabindex="-1" aria-labelledby="inspectionAreaValidationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="inspectionAreaValidationModalLabel">Inspection Area</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0" id="inspectionAreaValidationMessage"></p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-primary" type="button" data-bs-dismiss="modal">OK</button>
            </div>
        </div>
    </div>
</div>

<div class="d-flex align-items-center justify-content-between gap-3">
    <div class="btn-group" role="group" aria-label="Inspection area pages">
        <a class="btn btn-outline-secondary @(Model.Page == 1 ? "disabled" : string.Empty)"
           asp-controller="Settings"
           asp-action="InspectionAreas"
           asp-route-page="@previousPage">
            Previous
        </a>
        <a class="btn btn-outline-secondary @(Model.Page == Model.TotalPages ? "disabled" : string.Empty)"
           asp-controller="Settings"
           asp-action="InspectionAreas"
           asp-route-page="@nextPage">
            Next
        </a>
    </div>
    <span class="text-muted">Page @Model.Page of @Model.TotalPages</span>
</div>

@section Scripts {
    <script>
        (() => {
            const form = document.getElementById('addInspectionAreaForm');
            const nameInput = document.getElementById('inspectionAreaName');
            const editForm = document.getElementById('editInspectionAreaForm');
            const editIdInput = document.getElementById('editInspectionAreaId');
            const editNameInput = document.getElementById('editInspectionAreaName');
            const deleteButton = document.getElementById('deleteInspectionAreaButton');
            const validationMessage = document.getElementById('inspectionAreaValidationMessage');
            const validationModalElement = document.getElementById('inspectionAreaValidationModal');
            const validationModal = bootstrap.Modal.getOrCreateInstance(validationModalElement);
            const editModalElement = document.getElementById('editInspectionAreaModal');
            const editModal = bootstrap.Modal.getOrCreateInstance(editModalElement);

            const showValidationMessage = (message) => {
                validationMessage.textContent = message;
                validationModal.show();
            };

            const postForm = async (url, formData) => {
                const response = await fetch(url, {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                if (response.ok) {
                    window.location.reload();
                    return;
                }

                const result = await response.json().catch(() => null);
                showValidationMessage(result?.message || 'The inspection area could not be saved.');
            };

            form?.addEventListener('submit', async (event) => {
                event.preventDefault();

                if (!nameInput.value.trim()) {
                    showValidationMessage('Name cannot be blank');
                    nameInput.focus();
                    return;
                }

                const submitButton = form.querySelector('button[type="submit"]');
                submitButton.disabled = true;

                try {
                    await postForm(form.action, new FormData(form));
                } catch {
                    showValidationMessage('The inspection area could not be saved.');
                } finally {
                    submitButton.disabled = false;
                }
            });

            document.querySelectorAll('.clickable-table-row').forEach((row) => {
                const openEditModal = () => {
                    editIdInput.value = row.dataset.areaId || '';
                    editNameInput.value = row.dataset.areaName || '';
                    editModal.show();
                    editNameInput.focus();
                };

                row.addEventListener('click', openEditModal);
                row.addEventListener('keydown', (event) => {
                    if (event.key === 'Enter' || event.key === ' ') {
                        event.preventDefault();
                        openEditModal();
                    }
                });
            });

            editForm?.addEventListener('submit', async (event) => {
                event.preventDefault();

                if (!editNameInput.value.trim()) {
                    showValidationMessage('Name cannot be blank');
                    editNameInput.focus();
                    return;
                }

                const areaId = editIdInput.value;
                const submitButton = editForm.querySelector('button[type="submit"]');
                submitButton.disabled = true;

                try {
                    await postForm(`@Url.Action("UpdateInspectionArea", "Settings")/${areaId}`, new FormData(editForm));
                } catch {
                    showValidationMessage('The inspection area could not be saved.');
                } finally {
                    submitButton.disabled = false;
                }
            });

            deleteButton?.addEventListener('click', async () => {
                const areaId = editIdInput.value;
                if (!areaId) {
                    return;
                }

                deleteButton.disabled = true;

                try {
                    const formData = new FormData(editForm);
                    await postForm(`@Url.Action("DeleteInspectionArea", "Settings")/${areaId}`, formData);
                } catch {
                    showValidationMessage('The inspection area could not be deleted.');
                } finally {
                    deleteButton.disabled = false;
                }
            });
        })();
    </script>
}
