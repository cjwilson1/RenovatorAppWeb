@model RenovatorApp.Web.ViewModels.BuildingTypesViewModel

@{
    ViewData["Title"] = "Building Types";
    var previousPage = Math.Max(1, Model.Page - 1);
    var nextPage = Math.Min(Model.TotalPages, Model.Page + 1);
}

<div class="page-header-row">
    <div>
        <h1>Building Types</h1>
        <p class="text-muted">@Model.TotalBuildingTypes building type@(Model.TotalBuildingTypes == 1 ? string.Empty : "s")</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#addBuildingTypeModal">
            New Type
        </button>
        <a class="btn btn-secondary" asp-controller="Settings" asp-action="Index">Close</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert @Model.StatusClass" role="alert">@Model.StatusMessage</div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th scope="col">Name</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.BuildingTypes.Count == 0)
            {
                <tr>
                    <td class="text-muted">No building types found.</td>
                </tr>
            }
            else
            {
                @foreach (var buildingType in Model.BuildingTypes)
                {
                    <tr class="clickable-table-row"
                        tabindex="0"
                        data-building-type-id="@buildingType.BuildingTypeId"
                        data-building-type-name="@buildingType.Name">
                        <td>@buildingType.Name</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<div class="modal fade" id="addBuildingTypeModal" tabindex="-1" aria-labelledby="addBuildingTypeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-controller="Settings" asp-action="AddBuildingType" method="post" id="addBuildingTypeForm">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="addBuildingTypeModalLabel">Add new Building Type</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label" for="buildingTypeName">Name</label>
                    <input class="form-control" id="buildingTypeName" name="Name" />
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editBuildingTypeModal" tabindex="-1" aria-labelledby="editBuildingTypeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" id="editBuildingTypeForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editBuildingTypeId" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="editBuildingTypeModalLabel">Building Type</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label" for="editBuildingTypeName">Name</label>
                    <input class="form-control" id="editBuildingTypeName" name="Name" />
                </div>
                <div class="modal-footer justify-content-between">
                    <button class="btn btn-danger" type="button" id="deleteBuildingTypeButton">Delete</button>
                    <div class="d-flex gap-2">
                        <button class="btn btn-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                        <button class="btn btn-primary" type="submit">Save</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="buildingTypeValidationModal" tabindex="-1" aria-labelledby="buildingTypeValidationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="buildingTypeValidationModalLabel">Building Type</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0" id="buildingTypeValidationMessage"></p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-primary" type="button" data-bs-dismiss="modal">OK</button>
            </div>
        </div>
    </div>
</div>

<div class="d-flex align-items-center justify-content-between gap-3">
    <div class="btn-group" role="group" aria-label="Building type pages">
        <a class="btn btn-outline-secondary @(Model.Page == 1 ? "disabled" : string.Empty)"
           asp-controller="Settings"
           asp-action="BuildingTypes"
           asp-route-page="@previousPage">
            Previous
        </a>
        <a class="btn btn-outline-secondary @(Model.Page == Model.TotalPages ? "disabled" : string.Empty)"
           asp-controller="Settings"
           asp-action="BuildingTypes"
           asp-route-page="@nextPage">
            Next
        </a>
    </div>
    <span class="text-muted">Page @Model.Page of @Model.TotalPages</span>
</div>

@section Scripts {
    <script>
        (() => {
            const form = document.getElementById('addBuildingTypeForm');
            const nameInput = document.getElementById('buildingTypeName');
            const editForm = document.getElementById('editBuildingTypeForm');
            const editIdInput = document.getElementById('editBuildingTypeId');
            const editNameInput = document.getElementById('editBuildingTypeName');
            const deleteButton = document.getElementById('deleteBuildingTypeButton');
            const validationMessage = document.getElementById('buildingTypeValidationMessage');
            const validationModalElement = document.getElementById('buildingTypeValidationModal');
            const validationModal = bootstrap.Modal.getOrCreateInstance(validationModalElement);
            const editModalElement = document.getElementById('editBuildingTypeModal');
            const editModal = bootstrap.Modal.getOrCreateInstance(editModalElement);

            const showValidationMessage = (message) => {
                validationMessage.textContent = message;
                validationModal.show();
            };

            const postForm = async (url, formData, fallbackMessage) => {
                const response = await fetch(url, {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                if (response.ok) {
                    window.location.reload();
                    return;
                }

                const result = await response.json().catch(() => null);
                showValidationMessage(result?.message || fallbackMessage);
            };

            form?.addEventListener('submit', async (event) => {
                event.preventDefault();

                if (!nameInput.value.trim()) {
                    showValidationMessage('Name cannot be blank');
                    nameInput.focus();
                    return;
                }

                const submitButton = form.querySelector('button[type="submit"]');
                submitButton.disabled = true;

                try {
                    await postForm(form.action, new FormData(form), 'The building type could not be saved.');
                } catch {
                    showValidationMessage('The building type could not be saved.');
                } finally {
                    submitButton.disabled = false;
                }
            });

            document.querySelectorAll('.clickable-table-row').forEach((row) => {
                const openEditModal = () => {
                    editIdInput.value = row.dataset.buildingTypeId || '';
                    editNameInput.value = row.dataset.buildingTypeName || '';
                    editModal.show();
                    editNameInput.focus();
                };

                row.addEventListener('click', openEditModal);
                row.addEventListener('keydown', (event) => {
                    if (event.key === 'Enter' || event.key === ' ') {
                        event.preventDefault();
                        openEditModal();
                    }
                });
            });

            editForm?.addEventListener('submit', async (event) => {
                event.preventDefault();

                if (!editNameInput.value.trim()) {
                    showValidationMessage('Name cannot be blank');
                    editNameInput.focus();
                    return;
                }

                const buildingTypeId = editIdInput.value;
                const submitButton = editForm.querySelector('button[type="submit"]');
                submitButton.disabled = true;

                try {
                    await postForm(`@Url.Action("UpdateBuildingType", "Settings")/${buildingTypeId}`, new FormData(editForm), 'The building type could not be saved.');
                } catch {
                    showValidationMessage('The building type could not be saved.');
                } finally {
                    submitButton.disabled = false;
                }
            });

            deleteButton?.addEventListener('click', async () => {
                const buildingTypeId = editIdInput.value;
                if (!buildingTypeId) {
                    return;
                }

                deleteButton.disabled = true;

                try {
                    await postForm(`@Url.Action("DeleteBuildingType", "Settings")/${buildingTypeId}`, new FormData(editForm), 'The building type could not be deleted.');
                } catch {
                    showValidationMessage('The building type could not be deleted.');
                } finally {
                    deleteButton.disabled = false;
                }
            });
        })();
    </script>
}
