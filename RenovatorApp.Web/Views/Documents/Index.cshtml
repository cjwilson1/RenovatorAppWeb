@model RenovatorApp.Web.ViewModels.DocumentsIndexViewModel
@{
    ViewData["Title"] = "Documents";
    var previousPage = Math.Max(1, Model.Page - 1);
    var nextPage = Math.Min(Model.TotalPages, Model.Page + 1);
}

<div class="page-header-row">
    <div>
        <h1>Documents</h1>
        <p class="text-muted">@Model.TotalDocuments document@(Model.TotalDocuments == 1 ? string.Empty : "s")</p>
    </div>
</div>

<form class="customer-search-row" id="documentSearchForm" method="get">
    <input class="form-control"
           id="documentSearch"
           name="search"
           placeholder="Search Documents"
           type="search"
           value="@Model.Search" />
    <button class="btn btn-outline-secondary" id="clearDocumentSearch" type="button">Clear</button>
    <input id="documentPage" name="page" type="hidden" value="@Model.Page" />
</form>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th scope="col">Document Name</th>
                <th scope="col">Customer</th>
                <th scope="col">Inspection</th>
                <th scope="col">Document Type</th>
                <th scope="col">Create Date</th>
                <th scope="col">View</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Documents.Count == 0)
            {
                <tr>
                    <td class="text-muted" colspan="6">No documents found.</td>
                </tr>
            }
            else
            {
                @foreach (var document in Model.Documents)
                {
                    <tr class="clickable-table-row"
                        data-document-row
                        data-document-modal-id="documentModal-@document.DocumentId"
                        role="button"
                        tabindex="0"
                        aria-label="Open document @document.DocumentName">
                        <td><strong>@document.DocumentName</strong></td>
                        <td>@document.CustomerName</td>
                        <td>@document.InspectionTitle</td>
                        <td>@document.DocumentType</td>
                        <td>@FormatDate(document.CreateDate)</td>
                        <td>
                            <a class="btn btn-outline-primary btn-sm"
                               asp-controller="Documents"
                               asp-action="Open"
                               asp-route-id="@document.DocumentId"
                               data-document-view
                               target="_blank"
                               rel="noopener">
                                View
                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@foreach (var document in Model.Documents)
{
    <div class="modal fade" id="documentModal-@document.DocumentId" tabindex="-1" aria-labelledby="documentModalTitle-@document.DocumentId" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-controller="Documents" asp-action="Update" asp-route-id="@document.DocumentId" method="post">
                    @Html.AntiForgeryToken()
                    <input name="search" type="hidden" value="@Model.Search" />
                    <input name="page" type="hidden" value="@Model.Page" />
                    <div class="modal-header">
                        <h2 class="modal-title fs-5" id="documentModalTitle-@document.DocumentId">Document</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label" for="documentName-@document.DocumentId">Document Name</label>
                            <input class="form-control" id="documentName-@document.DocumentId" name="documentName" value="@document.DocumentName" />
                        </div>
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Customer</dt>
                            <dd class="col-sm-8">@document.CustomerName</dd>
                            <dt class="col-sm-4">Inspection</dt>
                            <dd class="col-sm-8">@document.InspectionTitle</dd>
                            <dt class="col-sm-4">Document Type</dt>
                            <dd class="col-sm-8">@document.DocumentType</dd>
                            <dt class="col-sm-4">Create Date</dt>
                            <dd class="col-sm-8">@FormatDate(document.CreateDate)</dd>
                        </dl>
                    </div>
                    <div class="modal-footer justify-content-between">
                        <button class="btn btn-danger"
                                data-document-delete-confirm
                                data-document-modal-id="documentModal-@document.DocumentId"
                                data-document-confirm-modal-id="deleteDocumentModal-@document.DocumentId"
                                type="button">
                            Delete
                        </button>
                        <div class="d-flex gap-2">
                            <button class="btn btn-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                            <button class="btn btn-primary" type="submit">Save</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal" id="deleteDocumentModal-@document.DocumentId" tabindex="-1" aria-labelledby="deleteDocumentModalLabel-@document.DocumentId" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="deleteDocumentModalLabel-@document.DocumentId">Delete Document</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">If you delete this document it cannot be recovered. Are you sure?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" type="button" data-bs-dismiss="modal">No</button>
                    <form asp-controller="Documents" asp-action="Delete" asp-route-id="@document.DocumentId" method="post">
                    @Html.AntiForgeryToken()
                        <input name="search" type="hidden" value="@Model.Search" />
                        <input name="page" type="hidden" value="@Model.Page" />
                        <button class="btn btn-danger" type="submit">Yes</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

<div class="d-flex align-items-center justify-content-between gap-3">
    <div class="btn-group" role="group" aria-label="Document pages">
        <a class="btn btn-outline-secondary @(Model.Page == 1 ? "disabled" : string.Empty)"
           asp-controller="Documents"
           asp-action="Index"
           asp-route-search="@Model.Search"
           asp-route-page="@previousPage">
            Previous
        </a>
        <a class="btn btn-outline-secondary @(Model.Page == Model.TotalPages ? "disabled" : string.Empty)"
           asp-controller="Documents"
           asp-action="Index"
           asp-route-search="@Model.Search"
           asp-route-page="@nextPage">
            Next
        </a>
    </div>
    <span class="text-muted">Page @Model.Page of @Model.TotalPages</span>
</div>

@section Scripts {
    <script>
        const searchForm = document.getElementById('documentSearchForm');
        const searchInput = document.getElementById('documentSearch');
        const pageInput = document.getElementById('documentPage');
        const clearSearchButton = document.getElementById('clearDocumentSearch');
        let searchTimer;

        searchInput?.addEventListener('input', () => {
            window.clearTimeout(searchTimer);
            const value = (searchInput.value || '').trim();
            searchTimer = window.setTimeout(() => {
                if (value.length === 0 || value.length >= 2) {
                    pageInput.value = '1';
                    searchForm.submit();
                }
            }, 350);
        });

        clearSearchButton?.addEventListener('click', () => {
            searchInput.value = '';
            pageInput.value = '1';
            searchForm.submit();
        });

        document.querySelectorAll('[data-document-row]').forEach((row) => {
            const openDocumentModal = (event) => {
                if (event?.target?.closest('[data-document-view], a, button, form')) {
                    return;
                }

                const modal = document.getElementById(row.dataset.documentModalId);
                if (!modal) {
                    return;
                }

                bootstrap.Modal.getOrCreateInstance(modal).show();
            };

            row.addEventListener('click', openDocumentModal);
            row.addEventListener('keydown', (event) => {
                if (event.key === 'Enter' || event.key === ' ') {
                    event.preventDefault();
                    openDocumentModal(event);
                }
            });
        });

        document.querySelectorAll('[data-document-delete-confirm]').forEach((button) => {
            button.addEventListener('click', () => {
                const editModal = document.getElementById(button.dataset.documentModalId);
                const confirmModal = document.getElementById(button.dataset.documentConfirmModalId);
                if (!editModal || !confirmModal) {
                    return;
                }

                const confirmInstance = bootstrap.Modal.getOrCreateInstance(confirmModal);
                editModal.addEventListener('hidden.bs.modal', () => confirmInstance.show(), { once: true });
                bootstrap.Modal.getOrCreateInstance(editModal).hide();
            });
        });
    </script>
}

@functions {
    private static string FormatDate(DateTime value)
    {
        return value.ToLocalTime().ToString("g");
    }
}
