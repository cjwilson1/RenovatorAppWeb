@model RenovatorApp.Web.ViewModels.InspectorsIndexViewModel

@{
    ViewData["Title"] = "Inspectors";
    var previousPage = Math.Max(1, Model.Page - 1);
    var nextPage = Math.Min(Model.TotalPages, Model.Page + 1);
}

<div class="page-header-row">
    <div>
        <h1>Inspectors</h1>
        <p class="text-muted">@Model.TotalInspectors inspector@(Model.TotalInspectors == 1 ? string.Empty : "s")</p>
    </div>
    <a class="btn btn-primary" asp-controller="Inspectors" asp-action="Add">Add Inspector</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
        <tr>
            <th scope="col">First Name</th>
            <th scope="col">Last Name</th>
            <th scope="col">Hourly Rate</th>
            <th scope="col">Phone</th>
            <th scope="col">Email</th>
            <th scope="col">Default</th>
        </tr>
        </thead>
        <tbody>
        @if (Model.Inspectors.Count == 0)
        {
            <tr>
                <td class="text-muted" colspan="6">No inspectors found.</td>
            </tr>
        }
        else
        {
            @foreach (var inspector in Model.Inspectors)
            {
                <tr class="clickable-table-row"
                    data-href="@Url.Action("Edit", "Inspectors", new { id = inspector.Id })"
                    tabindex="0"
                    aria-label="Edit @($"{inspector.FirstName} {inspector.LastName}".Trim())">
                    <td>@inspector.FirstName</td>
                    <td>@inspector.LastName</td>
                    <td>@inspector.HourlyRate.ToString("C")</td>
                    <td>@inspector.Phone</td>
                    <td>@inspector.Email</td>
                    <td>@(inspector.IsDefault ? "Yes" : "No")</td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<div class="d-flex align-items-center justify-content-between gap-3">
    <div class="btn-group" role="group" aria-label="Inspector pages">
        <a class="btn btn-outline-secondary @(Model.Page == 1 ? "disabled" : string.Empty)"
           asp-controller="Inspectors"
           asp-action="Index"
           asp-route-page="@previousPage">
            Previous
        </a>
        <a class="btn btn-outline-secondary @(Model.Page == Model.TotalPages ? "disabled" : string.Empty)"
           asp-controller="Inspectors"
           asp-action="Index"
           asp-route-page="@nextPage">
            Next
        </a>
    </div>
    <span class="text-muted">Page @Model.Page of @Model.TotalPages</span>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.clickable-table-row').forEach((row) => {
            const navigate = () => {
                const href = row.getAttribute('data-href');
                if (href) {
                    window.location.href = href;
                }
            };

            row.addEventListener('click', navigate);
            row.addEventListener('keydown', (event) => {
                if (event.key === 'Enter' || event.key === ' ') {
                    event.preventDefault();
                    navigate();
                }
            });
        });
    </script>
}
