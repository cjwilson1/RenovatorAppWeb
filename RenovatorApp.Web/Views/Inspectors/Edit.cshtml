@model RenovatorApp.Web.ViewModels.InspectorEditViewModel

@{
    ViewData["Title"] = Model.IsEditMode ? "Edit Inspector" : "Add Inspector";
}

<div class="page-header-row">
    <div>
        <h1>@(Model.IsEditMode ? "Edit Inspector" : "Add Inspector")</h1>
        <p class="text-muted">@(Model.IsEditMode ? "Update inspector details." : "Create a new inspector.")</p>
    </div>
</div>

<form asp-controller="Inspectors" asp-action="Save" method="post">
    <input asp-for="Id" type="hidden" />

    <section class="detail-section detail-section-full">
        <h2>Inspector</h2>
        <div class="row g-3">
            <div class="col-12 col-md-6 col-lg-4">
                <label class="form-label" asp-for="FirstName"></label>
                <input class="form-control" asp-for="FirstName" />
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <label class="form-label" asp-for="LastName"></label>
                <input class="form-control" asp-for="LastName" />
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <label class="form-label" asp-for="HourlyRate"></label>
                <input class="form-control" asp-for="HourlyRate" type="number" min="0" step="0.01" />
                <span class="text-danger" asp-validation-for="HourlyRate"></span>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <label class="form-label" asp-for="Phone"></label>
                <input class="form-control" asp-for="Phone" />
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <label class="form-label" asp-for="Email"></label>
                <input class="form-control" asp-for="Email" />
                <span class="text-danger" asp-validation-for="Email"></span>
            </div>
            <div class="col-12">
                <div class="form-check">
                    <input class="form-check-input" asp-for="IsDefault" />
                    <label class="form-check-label" asp-for="IsDefault"></label>
                </div>
            </div>
        </div>
    </section>

    <div class="d-flex gap-2 mt-3">
        <button class="btn btn-primary" type="submit">Save</button>
        <a class="btn btn-outline-secondary" asp-controller="Inspectors" asp-action="Index">Back</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
