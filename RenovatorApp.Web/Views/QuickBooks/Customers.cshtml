@model RenovatorApp.Web.ViewModels.QuickBooksCustomersViewModel

@{
    ViewData["Title"] = "QuickBooks Customers";
}

<div class="page-header-row">
    <div>
        <h1>QuickBooks Customers</h1>
        <p class="text-muted">@Model.StatusMessage</p>
    </div>
    <a class="btn btn-secondary" asp-controller="Settings" asp-action="Index">Settings</a>
</div>

@if (!Model.IsConnected)
{
    <section class="empty-state">
        <p>Connect QuickBooks from Settings before retrieving customers.</p>
    </section>
}
else if (Model.Customers.Count == 0)
{
    <section class="empty-state">
        <p>No QuickBooks customers were returned.</p>
    </section>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th scope="col">Display Name</th>
                    <th scope="col">Company</th>
                    <th scope="col">Contact</th>
                    <th scope="col">Email</th>
                    <th scope="col">Phone</th>
                    <th scope="col">Active</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var customer in Model.Customers)
                {
                    <tr>
                        <td>
                            <strong>@customer.DisplayName</strong>
                            <div class="small text-muted">ID @customer.Id</div>
                        </td>
                        <td>@customer.CompanyName</td>
                        <td>@string.Join(" ", new[] { customer.GivenName, customer.FamilyName }.Where(value => !string.IsNullOrWhiteSpace(value)))</td>
                        <td>@customer.Email</td>
                        <td>@customer.Phone</td>
                        <td>@customer.Active</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
