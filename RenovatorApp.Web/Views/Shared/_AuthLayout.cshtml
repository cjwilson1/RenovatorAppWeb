<!DOCTYPE html>
@inject RenovatorApp.Web.Services.BuildInfoService BuildInfo
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RenovatorApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RenovatorApp.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center gap-2 py-1" asp-controller="Account" asp-action="Login">
                    <img src="~/images/AppIconWeb.png" alt="RenovatorWeb logo" style="height: 42px; width: auto;" />
                    <span>RenovatorWeb</span>
                </a>
            </div>
        </nav>
    </header>

    <div class="container-fluid app-content-container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container-fluid app-content-container footer-content">
            <span>&copy; 2026 - RenovatorWeb</span>
            <span>@BuildInfo.DisplayVersion</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
