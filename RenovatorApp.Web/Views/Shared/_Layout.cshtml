<!DOCTYPE html>
@using Microsoft.EntityFrameworkCore
@inject RenovatorApp.Web.Services.BuildInfoService BuildInfo
@inject RenovatorApp.Infrastructure.Data.RenovatorAppDbContext DbContext
@inject RenovatorApp.Web.Services.CurrentUserSession CurrentUserSession
@{
    var appIconUrl = Url.Content("~/images/AppIconWeb.png");
    if (User.Identity?.IsAuthenticated == true)
    {
        var renoCompanyId = CurrentUserSession.RenoCompanyID;
        var companyIconUrl = await DbContext.AppSettings
            .AsNoTracking()
            .Where(setting => setting.RenoCompanyID == renoCompanyId && setting.Name == "Company:IconUrl")
            .Select(setting => setting.Value)
            .FirstOrDefaultAsync();

        if (!string.IsNullOrWhiteSpace(companyIconUrl))
        {
            appIconUrl = Url.Content(companyIconUrl);
        }
    }
}
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RenovatorApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RenovatorApp.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center gap-2 py-1" asp-area="" asp-controller="Home" asp-action="Index">
                    <img class="app-header-icon" src="@appIconUrl" alt="RenovatorWeb logo" />
                    <span>RenovatorWeb</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Inspections" asp-action="Index">Inspections</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Calendar" asp-action="Index">Calendar</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Customers" asp-action="Index">Customers</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Documents" asp-action="Index">Documents</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Properties" asp-action="Index">Properties</a>
                        </li>
                        @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Employees" asp-action="Index">Employees</a>
                            </li>
                            <li class="nav-item settings-nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Settings" asp-action="Index">Settings</a>
                            </li>
                        }
                    </ul>
                </div>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="dropdown user-menu">
                        <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            @User.Identity.Name
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            @if (User.IsInRole("SuperAdmin"))
                            {
                                <li>
                                    <a class="dropdown-item" asp-controller="SuperAdmin" asp-action="Index">Administration</a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                            }
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button class="dropdown-item" type="submit">Logout</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
            </div>
        </nav>
    </header>
    <div class="container-fluid app-content-container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container-fluid app-content-container footer-content">
            <span>&copy; 2026 - RenovatorWeb</span>
            <span>@BuildInfo.DisplayVersion</span>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
