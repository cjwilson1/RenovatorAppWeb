@model RenovatorApp.Web.ViewModels.InspectionDetailViewModel
@using RenovatorApp.Infrastructure.Models
@{
    ViewData["Title"] = Model.Inspection.Title;
}

<style>
    .detach-trip-confirmation {
        z-index: 1065;
    }

    .modal-backdrop.show + .modal-backdrop.show {
        z-index: 1060;
    }
</style>

<div class="page-header-row">
    <div>
        <h1>@Model.Inspection.Title</h1>
        <p class="text-muted">@Model.Inspection.InspectionDate.ToString("d")</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-danger" type="button" data-bs-toggle="modal" data-bs-target="#deleteInspectionModal">
            Delete
        </button>
        <a class="btn btn-outline-primary"
           asp-controller="Inspections"
           asp-action="Edit"
           asp-route-id="@Model.Inspection.Id">
            Edit Inspection
        </a>
        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#createReportModal">
            Create Inspection Report
        </button>
    </div>
</div>

<div class="modal" id="deleteInspectionModal" tabindex="-1" aria-labelledby="deleteInspectionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="deleteInspectionModalLabel">Delete Inspection</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                If you delete this Inspection, all inspection data will be deleted, and you will not be able to recover it. Are you sure?
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" type="button" data-bs-dismiss="modal">No</button>
                <form asp-controller="Inspections" asp-action="Delete" asp-route-id="@Model.Inspection.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-danger" type="submit">Yes</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="createReportModal" tabindex="-1" aria-labelledby="createReportModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="createReportModalLabel">Create Inspection Report</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form asp-controller="Inspections" asp-action="ReportPdf" asp-route-id="@Model.Inspection.Id" method="post">
                    <div class="mb-3">
                        <label class="form-label" for="reportName">Report Name</label>
                        <input class="form-control" id="reportName" name="reportName" value="@Model.DefaultReportName" />
                    </div>
                    <p class="mb-3">Choose a document format.</p>
                    <div class="d-grid gap-2">
                        <button class="btn btn-primary" type="submit">PDF</button>
                        <button class="btn btn-outline-secondary" type="button" disabled>Word</button>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="detail-grid">
    <section class="detail-section">
        <h2>General</h2>
        <dl>
            <dt>Inspector</dt>
            <dd>@Model.Inspection.InspectorName</dd>
            <dt>Last Updated</dt>
            <dd>@Model.Inspection.UpdatedAtUtc.ToLocalTime().ToString("g")</dd>
            <dt>Notes</dt>
            <dd>@(string.IsNullOrWhiteSpace(Model.Inspection.GeneralNotes) ? "None" : Model.Inspection.GeneralNotes)</dd>
        </dl>
    </section>

    <section class="detail-section">
        <h2>Customer</h2>
        @if (Model.Inspection.Customer is null)
        {
            <p>No customer assigned</p>
        }
        else
        {
            <dl>
                <dt>Name</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.CustomerName) ? "No customer assigned" : Model.CustomerName)</dd>
                <dt>Phone</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.Inspection.Customer.PrimaryPhone) ? "No phone number" : Model.Inspection.Customer.PrimaryPhone)</dd>
                <dt>Email</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.Inspection.Customer.PrimaryEmailAddress) ? "No email address" : Model.Inspection.Customer.PrimaryEmailAddress)</dd>
                <dt>Address</dt>
                <dd>@GetCustomerAddress()</dd>
            </dl>
        }
    </section>

    <section class="detail-section">
        <h2>Property</h2>
        <p>@(string.IsNullOrWhiteSpace(Model.PropertyAddress) ? "No property address" : Model.PropertyAddress)</p>
    </section>

    <section class="detail-section detail-section-wide">
        <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
            <h2 class="mb-0">Mileage</h2>
            <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#attachTripModal">
                Attach Trip
            </button>
        </div>
        @if (Model.MileageTrackingRecords.Count == 0)
        {
            <p>No mileage tracking records attached to this inspection.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th scope="col">Start Time</th>
                            <th scope="col">Elapsed Time</th>
                            <th scope="col" class="text-end">Total Mileage</th>
                            <th scope="col">End Time</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var trip in Model.MileageTrackingRecords)
                        {
                            <tr>
                                <td>
                                    <button class="btn btn-link p-0 align-baseline"
                                            type="button"
                                            data-bs-toggle="modal"
                                            data-bs-target="#mileageTripModal-@trip.UniqueId">
                                        @FormatDateTime(trip.TrackingStartedAtUtc)
                                    </button>
                                </td>
                                <td>@FormatElapsedTime(trip.TotalTime)</td>
                                <td class="text-end">@FormatMileage(trip.TotalMileage)</td>
                                <td>@FormatDateTime(trip.EndTimeUtc)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <div class="modal" id="attachTripModal" tabindex="-1" aria-labelledby="attachTripModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="attachTripModalLabel">Attach Trip</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="form-check mb-3">
                        <input class="form-check-input" id="showAttachedTrips" type="checkbox" />
                        <label class="form-check-label" for="showAttachedTrips">Show attached trips</label>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th scope="col">Start Time</th>
                                    <th scope="col">Elapsed Time</th>
                                    <th scope="col" class="text-end">Total Mileage</th>
                                    <th scope="col">End Time</th>
                                    <th scope="col">Inspection</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.MileageTrackingAttachRecords.Count == 0)
                                {
                                    <tr>
                                        <td class="text-muted" colspan="5">No mileage tracking records found.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var trip in Model.MileageTrackingAttachRecords)
                                    {
                                        <tr class="clickable-table-row"
                                            data-attach-trip-row
                                            data-trip-id="@trip.UniqueId"
                                            data-is-attached="@trip.InspectionId.HasValue.ToString().ToLowerInvariant()"
                                            tabindex="0"
                                            aria-label="Attach trip from @FormatDateTime(trip.TrackingStartedAtUtc)">
                                            <td>@FormatDateTime(trip.TrackingStartedAtUtc)</td>
                                            <td>@FormatElapsedTime(trip.TotalTime)</td>
                                            <td class="text-end">@FormatMileage(trip.TotalMileage)</td>
                                            <td>@FormatDateTime(trip.EndTimeUtc)</td>
                                            <td>@(string.IsNullOrWhiteSpace(trip.InspectionTitle) ? "None" : trip.InspectionTitle)</td>
                                        </tr>
                                    }
                                }
                                <tr class="d-none" id="attachTripEmptyRow">
                                    <td class="text-muted" colspan="5">No unattached mileage tracking records found.</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" type="button" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal detach-trip-confirmation" id="confirmAttachTripModal" tabindex="-1" aria-labelledby="confirmAttachTripModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="confirmAttachTripModalLabel">Attach to Inspection</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">Do you want to attach this trip to the current inspection?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" type="button" data-bs-dismiss="modal">No</button>
                    <form asp-controller="Inspections" asp-action="AttachMileage" asp-route-id="@Model.Inspection.Id" method="post">
                        @Html.AntiForgeryToken()
                        <input id="attachMileageTripId" name="tripId" type="hidden" />
                        <button class="btn btn-primary" type="submit">Yes</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    @foreach (var trip in Model.MileageTrackingRecords)
    {
        <div class="modal" id="mileageTripModal-@trip.UniqueId" tabindex="-1" aria-labelledby="mileageTripModalLabel-@trip.UniqueId" aria-hidden="true">
            <div class="modal-dialog modal-xl modal-dialog-scrollable">
                <div class="modal-content">
                    <div class="modal-header">
                        <h2 class="modal-title fs-5" id="mileageTripModalLabel-@trip.UniqueId">Trip</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <section class="detail-section mb-4">
                            <h2>Trip Details</h2>
                            <div class="table-responsive">
                                <table class="table table-striped align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th scope="col">Start Time</th>
                                            <th scope="col">Elapsed Time</th>
                                            <th scope="col" class="text-end">Total Mileage</th>
                                            <th scope="col">End Time</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>@FormatDateTime(trip.TrackingStartedAtUtc)</td>
                                            <td>@FormatElapsedTime(trip.TotalTime)</td>
                                            <td class="text-end">@FormatMileage(trip.TotalMileage)</td>
                                            <td>@FormatDateTime(trip.EndTimeUtc)</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </section>

                        <section class="detail-section mb-4">
                            <h2>Map</h2>
                            @if (string.IsNullOrWhiteSpace(trip.MapImageUrl))
                            {
                                <p class="text-muted">No map is available for this trip.</p>
                            }
                            else
                            {
                                <img class="trip-map-image"
                                     src="@trip.MapImageUrl"
                                     alt="Static map of trip waypoints" />
                                <p class="text-muted mt-2">
                                    Powered by <a href="https://www.geoapify.com/" target="_blank" rel="noopener">Geoapify</a>
                                    and <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener">OpenStreetMap contributors</a>
                                </p>
                            }
                        </section>

                        <section class="detail-section">
                            <h2>Waypoints</h2>
                            <div class="table-responsive">
                                <table class="table table-striped align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th scope="col">#</th>
                                            <th scope="col">Waypoint Time</th>
                                            <th scope="col" class="text-end">Cumulative Miles</th>
                                            <th scope="col">GPS Coordinates</th>
                                            <th scope="col">Location</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (trip.Waypoints.Count == 0)
                                        {
                                            <tr>
                                                <td class="text-muted" colspan="5">No waypoints found.</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @for (var waypointIndex = 0; waypointIndex < trip.Waypoints.Count; waypointIndex++)
                                            {
                                                var waypoint = trip.Waypoints[waypointIndex];
                                                <tr>
                                                    <td>@(waypointIndex + 1)</td>
                                                    <td>@FormatDateTime(waypoint.WaypointTimeUtc)</td>
                                                    <td class="text-end">@FormatMileage(waypoint.CumulativeMiles)</td>
                                                    <td>@FormatWaypointCoordinates(waypoint.GpsCoordinates, waypointIndex)</td>
                                                    <td>@FormatLocation(waypoint.Location)</td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </section>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-danger me-4"
                                type="button"
                                data-detach-trip-button
                                data-confirm-modal-id="detachTripModal-@trip.UniqueId">
                            Remove from Inspection
                        </button>
                        <button class="btn btn-secondary" type="button" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal detach-trip-confirmation" id="detachTripModal-@trip.UniqueId" tabindex="-1" aria-labelledby="detachTripModalLabel-@trip.UniqueId" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h2 class="modal-title fs-5" id="detachTripModalLabel-@trip.UniqueId">Detach Trip</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-0">Are you sure you want to remove this Trip from the inspection?</p>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" type="button" data-bs-dismiss="modal">No</button>
                        <form asp-controller="Inspections" asp-action="DetachMileage" asp-route-id="@Model.Inspection.Id" method="post">
                            @Html.AntiForgeryToken()
                            <input name="tripId" type="hidden" value="@trip.UniqueId" />
                            <button class="btn btn-danger" type="submit">Yes</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }

    <section class="detail-section detail-section-wide">
        <h2>Buildings</h2>
        @if (Model.Inspection.Property.Buildings.Count == 0)
        {
            <p>No buildings found.</p>
        }
        else
        {
            <div class="building-list">
                @foreach (var building in GetBuildings())
                {
                    var areas = GetAreas(building).ToList();

                    <article class="building-detail">
                        <div class="building-detail-header">
                            <div>
                                <h3>@building.Name</h3>
                                <p class="text-muted">@GetBuildingTypeName(building)</p>
                            </div>
                            <span class="badge text-bg-light">@areas.Count area@(areas.Count == 1 ? string.Empty : "s")</span>
                        </div>

                        @if (areas.Count == 0)
                        {
                            <p class="text-muted mb-0">No inspection areas found.</p>
                        }
                        else
                        {
                            <div class="area-list">
                                @foreach (var area in areas)
                                {
                                    var notes = area.AreaNotes
                                        .OrderBy(note => note.CreatedAtUtc)
                                        .ToList();

                                    <section class="area-detail">
                                        <div class="area-detail-header">
                                            <div>
                                                <h4>@area.DisplayName</h4>
                                                <p class="text-muted">@GetAreaTypeName(area)</p>
                                            </div>
                                            <span class="text-muted">Rating: @FormatRating(area.OverallRating)</span>
                                        </div>

                                        @if (notes.Count == 0)
                                        {
                                            <p class="text-muted mb-0">No notes found.</p>
                                        }
                                        else
                                        {
                                            <div class="note-list">
                                                @foreach (var note in notes)
                                                {
                                                    var estimateItems = note.EstimateItems
                                                        .OrderBy(item => item.Name)
                                                        .ToList();
                                                    var photos = note.Photos
                                                        .Where(photo => photo.Data.Length > 0)
                                                        .OrderBy(photo => photo.CreatedAtUtc)
                                                        .ToList();
                                                    var totalCost = estimateItems.Sum(item => item.Cost);
                                                    var totalHours = estimateItems.Sum(item => item.Hours);

                                                    <article class="note-detail">
                                                        <div class="note-detail-header">
                                                            <h5>Note</h5>
                                                            <span class="text-muted">@note.CreatedAtUtc.ToLocalTime().ToString("g")</span>
                                                        </div>
                                                        <p class="note-text">@(string.IsNullOrWhiteSpace(note.Text) ? "No note text." : note.Text)</p>

                                                        <div class="estimate-summary">
                                                            <span><strong>Estimate:</strong> @FormatCurrency(totalCost)</span>
                                                            <span><strong>Hours:</strong> @FormatHours(totalHours)</span>
                                                        </div>

                                                        @if (estimateItems.Count > 0)
                                                        {
                                                            <div class="table-responsive">
                                                                <table class="table table-sm estimate-table mb-0">
                                                                    <thead>
                                                                        <tr>
                                                                            <th scope="col">Item</th>
                                                                            <th scope="col" class="text-end">Cost</th>
                                                                            <th scope="col" class="text-end">Hours</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                        @foreach (var item in estimateItems)
                                                                        {
                                                                            <tr>
                                                                                <td>@item.Name</td>
                                                                                <td class="text-end">@FormatCurrency(item.Cost)</td>
                                                                                <td class="text-end">@FormatHours(item.Hours)</td>
                                                                            </tr>
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        }

                                                        <div>
                                                            <h6>Pictures</h6>
                                                            @if (photos.Count == 0)
                                                            {
                                                                <p class="text-muted mb-0">No pictures found.</p>
                                                            }
                                                            else
                                                            {
                                                                <div class="photo-list">
                                                                    @foreach (var photo in photos)
                                                                    {
                                                                        <img src="@GetPhotoSource(photo)" alt="@GetPhotoAlt(photo)" />
                                                                    }
                                                                </div>
                                                            }
                                                        </div>
                                                    </article>
                                                }
                                            </div>
                                        }
                                    </section>
                                }
                            </div>
                        }
                    </article>
                }
            </div>
        }
    </section>
</div>

@section Scripts {
    <script>
        const showAttachedTrips = document.getElementById('showAttachedTrips');
        const attachTripEmptyRow = document.getElementById('attachTripEmptyRow');
        const attachMileageTripId = document.getElementById('attachMileageTripId');
        const confirmAttachTripModal = document.getElementById('confirmAttachTripModal');

        function updateAttachTripRows() {
            const showAttached = showAttachedTrips?.checked || false;
            let visibleCount = 0;

            document.querySelectorAll('[data-attach-trip-row]').forEach(row => {
                const isAttached = row.dataset.isAttached === 'true';
                const isVisible = showAttached || !isAttached;

                row.classList.toggle('d-none', !isVisible);

                if (isVisible) {
                    visibleCount++;
                }
            });

            attachTripEmptyRow?.classList.toggle('d-none', visibleCount > 0);
        }

        showAttachedTrips?.addEventListener('change', updateAttachTripRows);

        document.querySelectorAll('[data-attach-trip-row]').forEach(row => {
            const openAttachConfirmation = () => {
                if (attachMileageTripId) {
                    attachMileageTripId.value = row.dataset.tripId || '';
                }

                if (confirmAttachTripModal) {
                    bootstrap.Modal.getOrCreateInstance(confirmAttachTripModal).show();
                }
            };

            row.addEventListener('click', openAttachConfirmation);
            row.addEventListener('keydown', event => {
                if (event.key === 'Enter' || event.key === ' ') {
                    event.preventDefault();
                    openAttachConfirmation();
                }
            });
        });

        updateAttachTripRows();

        document.querySelectorAll('[data-detach-trip-button]').forEach(button => {
            button.addEventListener('click', () => {
                const confirmModal = document.getElementById(button.dataset.confirmModalId || '');

                if (confirmModal) {
                    bootstrap.Modal.getOrCreateInstance(confirmModal).show();
                }
            });
        });
    </script>
}

@functions {
    private IEnumerable<Building> GetBuildings()
    {
        return Model.Inspection.Property.Buildings
            .OrderBy(building => building.SortOrder)
            .ThenBy(building => building.Name);
    }

    private IEnumerable<InspectionArea> GetAreas(Building building)
    {
        return Model.Inspection.Property.Areas
            .Where(area => area.BuildingId == building.Id)
            .OrderBy(area => area.SortOrder)
            .ThenBy(area => area.DisplayName);
    }

    private static string GetBuildingTypeName(Building building)
    {
        return string.IsNullOrWhiteSpace(building.BuildingType?.Name)
            ? "No building type"
            : building.BuildingType.Name;
    }

    private static string GetAreaTypeName(InspectionArea area)
    {
        return string.IsNullOrWhiteSpace(area.AreaType?.Name)
            ? "No area type"
            : area.AreaType.Name;
    }

    private static string FormatRating(int rating)
    {
        return rating == 0 ? "n/a" : rating.ToString();
    }

    private static string FormatCurrency(decimal value)
    {
        return $"${value:N2}";
    }

    private static string FormatHours(decimal value)
    {
        return value.ToString("0.##");
    }

    private static string FormatDateTime(DateTime value)
    {
        return value.ToLocalTime().ToString("g");
    }

    private static string FormatElapsedTime(TimeSpan value)
    {
        return value.TotalHours >= 1
            ? $"{(int)value.TotalHours}:{value.Minutes:00}:{value.Seconds:00}"
            : $"{value.Minutes:00}:{value.Seconds:00}";
    }

    private static string FormatMileage(double value)
    {
        return $"{value:N2}";
    }

    private static string FormatWaypointCoordinates(string value, int index)
    {
        return index == 0 && string.IsNullOrWhiteSpace(value)
            ? "Trip start"
            : value;
    }

    private static string FormatLocation(string value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? "-"
            : value;
    }

    private static string GetPhotoSource(InspectionAreaNotePhoto photo)
    {
        var contentType = string.IsNullOrWhiteSpace(photo.ContentType) ? "image/jpeg" : photo.ContentType;

        return $"data:{contentType};base64,{Convert.ToBase64String(photo.Data)}";
    }

    private static string GetPhotoAlt(InspectionAreaNotePhoto photo)
    {
        return string.IsNullOrWhiteSpace(photo.FileName) ? "Inspection note picture" : photo.FileName;
    }

    private string GetCustomerAddress()
    {
        var customer = Model.Inspection.Customer;

        if (customer is null)
        {
            return "No customer address";
        }

        var streetAddress = string.Join(" ", new[] { customer.BillAddress?.Street1, customer.BillAddress?.Street2 }
            .Where(value => !string.IsNullOrWhiteSpace(value)));
        var cityState = string.Join(", ", new[] { customer.BillAddress?.City, customer.BillAddress?.State }
            .Where(value => !string.IsNullOrWhiteSpace(value)));
        var cityStateZip = string.Join(" ", new[] { cityState, customer.BillAddress?.PostalCode }
            .Where(value => !string.IsNullOrWhiteSpace(value)));
        var fullAddress = string.Join(" - ", new[] { streetAddress, cityStateZip }
            .Where(value => !string.IsNullOrWhiteSpace(value)));

        return string.IsNullOrWhiteSpace(fullAddress) ? "No customer address" : fullAddress;
    }
}

