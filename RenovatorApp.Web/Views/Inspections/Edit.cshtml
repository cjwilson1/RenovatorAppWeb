@model RenovatorApp.Web.ViewModels.InspectionEditViewModel
@{
    ViewData["Title"] = Model.PageTitle;
}

<style>
    #findPartModal {
        z-index: 1065;
    }

    .modal-backdrop.show + .modal-backdrop.show {
        z-index: 1060;
    }
</style>

<div class="page-header-row">
    <div>
        <h1>@Model.PageTitle</h1>
    </div>
</div>

<form asp-controller="Inspections" asp-action="Edit" asp-route-id="@Model.Id" id="inspectionEditForm" method="post">
    <input asp-for="ForceNewCustomer" type="hidden" />
    <ul class="nav nav-tabs mb-3" id="inspectionEditTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="general-tab" data-bs-toggle="tab" data-bs-target="#general-panel" type="button" role="tab" aria-controls="general-panel" aria-selected="true">
                General
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="customer-tab" data-bs-toggle="tab" data-bs-target="#customer-panel" type="button" role="tab" aria-controls="customer-panel" aria-selected="false">
                Customer
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="property-tab" data-bs-toggle="tab" data-bs-target="#property-panel" type="button" role="tab" aria-controls="property-panel" aria-selected="false">
                Property
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="buildings-tab" data-bs-toggle="tab" data-bs-target="#buildings-panel" type="button" role="tab" aria-controls="buildings-panel" aria-selected="false">
                Buildings
            </button>
        </li>
    </ul>

    <div class="tab-content" id="inspectionEditTabContent">
        <div class="tab-pane fade show active" id="general-panel" role="tabpanel" aria-labelledby="general-tab" tabindex="0">
            <section class="detail-section">
                <h2>General</h2>

                <div class="mb-3">
                    <label class="form-label" asp-for="Title"></label>
                    <input class="form-control" asp-for="Title" type="text" required />
                    <span class="text-danger" asp-validation-for="Title"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label" asp-for="InspectionDate">Inspection Date</label>
                    <input class="form-control" asp-for="InspectionDate" asp-format="{0:yyyy-MM-dd}" type="date" min="2025-01-01" style="max-width: 14rem;" />
                </div>

                <div class="mb-3">
                    <label class="form-label" asp-for="InspectorName">Inspector</label>
                    <div class="input-group">
                        <input class="form-control" asp-for="InspectorName" type="text" />
                        <button class="btn btn-outline-secondary"
                                type="button"
                                data-bs-toggle="modal"
                                data-bs-target="#inspectorPickerModal"
                                aria-label="Select inspector">
                            <svg aria-hidden="true" fill="none" height="16" viewBox="0 0 24 24" width="16" xmlns="http://www.w3.org/2000/svg">
                                <path d="m21 21-4.35-4.35m1.35-5.65a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
                            </svg>
                        </button>
                    </div>
                </div>

                <div class="mb-0">
                    <label class="form-label" asp-for="GeneralNotes">General notes</label>
                    <textarea class="form-control" asp-for="GeneralNotes" rows="5"></textarea>
                </div>
            </section>
        </div>

        <div class="tab-pane fade" id="property-panel" role="tabpanel" aria-labelledby="property-tab" tabindex="0">
            <section class="detail-section">
                <h2>Property</h2>

                <div class="mb-3">
                    <label class="form-label" asp-for="PropertyAddress.Street1">Street 1</label>
                    <input class="form-control" asp-for="PropertyAddress.Street1" type="text" />
                </div>

                <div class="mb-3">
                    <label class="form-label" asp-for="PropertyAddress.Street2">Street 2</label>
                    <input class="form-control" asp-for="PropertyAddress.Street2" type="text" />
                </div>

                <div class="row">
                    <div class="col-md-5 mb-3">
                        <label class="form-label" asp-for="PropertyAddress.City">City</label>
                        <input class="form-control" asp-for="PropertyAddress.City" type="text" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label" asp-for="PropertyAddress.State"></label>
                        <input class="form-control" asp-for="PropertyAddress.State" type="text" />
                    </div>
                    <div class="col-md-4 mb-0">
                        <label class="form-label" asp-for="PropertyAddress.PostalCode">Postal Code</label>
                        <input class="form-control" asp-for="PropertyAddress.PostalCode" type="text" />
                    </div>
                </div>
            </section>
        </div>

        <div class="tab-pane fade" id="customer-panel" role="tabpanel" aria-labelledby="customer-tab" tabindex="0">
            <section class="detail-section">
                <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
                    <h2 class="mb-0">Customer</h2>
                    <button class="btn btn-primary"
                            type="button"
                            data-bs-toggle="modal"
                            data-bs-target="#findCustomerModal">
                        Find Customer
                    </button>
                </div>

                <input asp-for="Customer.CustomerId" type="hidden" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label" asp-for="Customer.FirstName">First Name</label>
                        <input class="form-control" asp-for="Customer.FirstName" type="text" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label" asp-for="Customer.LastName">Last Name</label>
                        <input class="form-control" asp-for="Customer.LastName" type="text" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label" asp-for="Customer.CompanyName">Company Name</label>
                    <input class="form-control" asp-for="Customer.CompanyName" type="text" />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label" asp-for="Customer.Phone"></label>
                        <input class="form-control" asp-for="Customer.Phone" type="tel" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label" asp-for="Customer.Email"></label>
                        <input class="form-control" asp-for="Customer.Email" type="email" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label" asp-for="Customer.Street1">Street 1</label>
                    <input class="form-control" asp-for="Customer.Street1" type="text" />
                </div>

                <div class="mb-3">
                    <label class="form-label" asp-for="Customer.Street2">Street 2</label>
                    <input class="form-control" asp-for="Customer.Street2" type="text" />
                </div>

                <div class="row">
                    <div class="col-md-5 mb-3">
                        <label class="form-label" asp-for="Customer.City"></label>
                        <input class="form-control" asp-for="Customer.City" type="text" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label" asp-for="Customer.State"></label>
                        <input class="form-control" asp-for="Customer.State" type="text" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label" asp-for="Customer.PostalCode">Postal Code</label>
                        <input class="form-control" asp-for="Customer.PostalCode" type="text" />
                    </div>
                </div>

                <div class="mb-0">
                    <label class="form-label" asp-for="Customer.Notes"></label>
                    <textarea class="form-control" asp-for="Customer.Notes" rows="5"></textarea>
                </div>
            </section>
        </div>

        <div class="tab-pane fade" id="buildings-panel" role="tabpanel" aria-labelledby="buildings-tab" tabindex="0">
            <section class="detail-section">
                <h2>Buildings</h2>

                @if (Model.Buildings.Count == 0)
                {
                    <p class="text-muted mb-0">No buildings found.</p>
                }
                else
                {
                    <div class="d-flex flex-wrap gap-2 mb-3" data-building-selector>
                        @for (var buildingIndex = 0; buildingIndex < Model.Buildings.Count; buildingIndex++)
                        {
                            var building = Model.Buildings[buildingIndex];
                            var isSelectedBuilding = buildingIndex == 0;

                            <input asp-for="Buildings[buildingIndex].Id" type="hidden" />
                            <button class="btn @(isSelectedBuilding ? "btn-primary" : "btn-outline-primary")"
                                    type="button"
                                    data-building-target="building-@building.Id"
                                    aria-pressed="@(isSelectedBuilding ? "true" : "false")">
                                @building.BuildingTypeName
                            </button>
                        }
                    </div>

                    @for (var buildingIndex = 0; buildingIndex < Model.Buildings.Count; buildingIndex++)
                    {
                        var building = Model.Buildings[buildingIndex];
                        var isSelectedBuilding = buildingIndex == 0;

                        <div class="@(isSelectedBuilding ? string.Empty : "d-none")" data-building-panel="building-@building.Id">
                            @if (building.Areas.Count == 0)
                            {
                                <p class="text-muted mb-0">No inspection areas found for this building.</p>
                            }
                            else
                            {
                                <h3 class="h6 fw-bold">Areas</h3>
                                <div class="d-flex flex-wrap gap-2 mb-3" data-area-selector>
                                    @for (var areaIndex = 0; areaIndex < building.Areas.Count; areaIndex++)
                                    {
                                        var area = building.Areas[areaIndex];
                                        var isSelectedArea = areaIndex == 0;

                                        <input asp-for="Buildings[buildingIndex].Areas[areaIndex].Id" type="hidden" />
                                        <button class="btn @(isSelectedArea ? "btn-secondary" : "btn-outline-secondary")"
                                                type="button"
                                                data-area-target="area-@area.Id"
                                                aria-pressed="@(isSelectedArea ? "true" : "false")">
                                            @area.AreaTypeName
                                        </button>
                                    }
                                </div>

                                @for (var areaIndex = 0; areaIndex < building.Areas.Count; areaIndex++)
                                {
                                    var area = building.Areas[areaIndex];
                                    var isSelectedArea = areaIndex == 0;
                                    var ratingOptions = new[]
                                    {
                                        (Value: 0, Label: "0 n/a", CompactLabel: "n/a"),
                                        (Value: 1, Label: "1 bad", CompactLabel: string.Empty),
                                        (Value: 2, Label: "2", CompactLabel: string.Empty),
                                        (Value: 3, Label: "3 Average", CompactLabel: "3 Avg"),
                                        (Value: 4, Label: "4", CompactLabel: string.Empty),
                                        (Value: 5, Label: "5 best", CompactLabel: string.Empty)
                                    };

                                    <div class="@(isSelectedArea ? string.Empty : "d-none")" data-area-panel="area-@area.Id">
                                        <h3 class="h5">@area.DisplayName</h3>
                                        <div class="d-flex flex-wrap gap-3 mb-3">
                                            @foreach (var ratingOption in ratingOptions)
                                            {
                                                var radioId = $"building-{buildingIndex}-area-{areaIndex}-rating-{ratingOption.Value}";

                                                <div class="form-check">
                                                    <input class="form-check-input"
                                                           id="@radioId"
                                                           name="Buildings[@buildingIndex].Areas[@areaIndex].OverallRating"
                                                           type="radio"
                                                           value="@ratingOption.Value"
                                                           checked="@(area.OverallRating == ratingOption.Value)" />
                                                    <label class="form-check-label" for="@radioId">
                                                        @if (string.IsNullOrWhiteSpace(ratingOption.CompactLabel))
                                                        {
                                                            @ratingOption.Label
                                                        }
                                                        else
                                                        {
                                                            <span class="d-sm-none">@ratingOption.CompactLabel</span>
                                                            <span class="d-none d-sm-inline">@ratingOption.Label</span>
                                                        }
                                                    </label>
                                                </div>
                                            }
                                        </div>

                                        @if (area.Notes.Count == 0)
                                        {
                                            <p class="text-muted mb-0">No notes found for this area.</p>
                                        }
                                        else
                                        {
                                            <div class="d-grid gap-3">
                                                @for (var noteIndex = 0; noteIndex < area.Notes.Count; noteIndex++)
                                                {
                                                    var note = area.Notes[noteIndex];
                                                    var estimateTableId = $"estimate-items-{note.Id}";
                                                    var estimateEmptyId = $"estimate-empty-{note.Id}";
                                                    var estimateInputsId = $"estimate-inputs-{note.Id}";
                                                    var estimatePrefix = $"Buildings[{buildingIndex}].Areas[{areaIndex}].Notes[{noteIndex}].EstimateItems";

                                                    <section class="border rounded p-3">
                                                        <input asp-for="Buildings[buildingIndex].Areas[areaIndex].Notes[noteIndex].Id" type="hidden" />
                                                        <p class="mb-3">@(string.IsNullOrWhiteSpace(note.Text) ? "No note text." : note.Text)</p>

                                                        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3">
                                                            <div class="d-flex flex-wrap gap-3">
                                                                <span><strong>Estimate:</strong> <span data-estimate-total-cost="@note.Id">@FormatCurrency(note.EstimateCost)</span></span>
                                                                <span><strong>Hours:</strong> <span data-estimate-total-hours="@note.Id">@FormatHours(note.EstimateHours)</span></span>
                                                            </div>
                                                            <button class="btn btn-sm btn-outline-primary"
                                                                    type="button"
                                                                    data-add-part-note-id="@note.Id"
                                                                    data-add-part-table-id="@estimateTableId"
                                                                    data-add-part-empty-id="@estimateEmptyId"
                                                                    data-add-part-inputs-id="@estimateInputsId"
                                                                    data-add-part-prefix="@estimatePrefix"
                                                                    data-add-part-next-index="@note.EstimateItems.Count"
                                                                    data-bs-toggle="modal"
                                                                    data-bs-target="#addPartModal">
                                                                Add Part
                                                            </button>
                                                        </div>

                                                        <p class="text-muted @(note.EstimateItems.Count == 0 ? "mb-3" : "d-none")" id="@estimateEmptyId">No estimate items found.</p>
                                                        <div class="table-responsive mb-3 @(note.EstimateItems.Count == 0 ? "d-none" : string.Empty)" id="@estimateTableId">
                                                            <table class="table table-sm mb-0">
                                                                    <thead>
                                                                        <tr>
                                                                            <th scope="col">Name</th>
                                                                            <th scope="col" class="text-end">Cost</th>
                                                                            <th scope="col" class="text-end">Hours</th>
                                                                            <th scope="col" class="text-end">Actions</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                        @for (var estimateItemIndex = 0; estimateItemIndex < note.EstimateItems.Count; estimateItemIndex++)
                                                                        {
                                                                            var estimateItem = note.EstimateItems[estimateItemIndex];
                                                                            var estimateItemLocalId = $"estimate-item-{estimateItem.Id}";

                                                                            <tr data-estimate-item-row="@estimateItemLocalId">
                                                                                <td data-estimate-item-name>@estimateItem.Name</td>
                                                                                <td class="text-end" data-estimate-item-cost>@FormatCurrency(estimateItem.Cost)</td>
                                                                                <td class="text-end" data-estimate-item-hours>@FormatHours(estimateItem.Hours)</td>
                                                                                <td class="text-end">
                                                                                    <div class="d-inline-flex gap-1">
                                                                                        <button class="btn btn-sm btn-success"
                                                                                                type="button"
                                                                                                data-edit-estimate-item-id="@estimateItemLocalId"
                                                                                                data-edit-estimate-note-id="@note.Id"
                                                                                                aria-label="Edit estimate item">
                                                                                            <svg aria-hidden="true" fill="none" height="14" viewBox="0 0 24 24" width="14" xmlns="http://www.w3.org/2000/svg">
                                                                                                <path d="M12 20h9" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
                                                                                                <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
                                                                                            </svg>
                                                                                        </button>
                                                                                        <button class="btn btn-sm btn-danger"
                                                                                                type="button"
                                                                                                data-delete-estimate-item-id="@estimateItemLocalId"
                                                                                                data-delete-estimate-note-id="@note.Id"
                                                                                                data-delete-estimate-table-id="@estimateTableId"
                                                                                                data-delete-estimate-empty-id="@estimateEmptyId"
                                                                                                aria-label="Delete estimate item">
                                                                                            <svg aria-hidden="true" fill="none" height="14" viewBox="0 0 24 24" width="14" xmlns="http://www.w3.org/2000/svg">
                                                                                                <path d="M3 6h18" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
                                                                                                <path d="M8 6V4h8v2" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
                                                                                                <path d="M19 6 18 20H6L5 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
                                                                                                <path d="M10 11v5M14 11v5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
                                                                                            </svg>
                                                                                        </button>
                                                                                    </div>
                                                                                </td>
                                                                            </tr>
                                                                        }
                                                                    </tbody>
                                                            </table>
                                                        </div>
                                                        <div id="@estimateInputsId">
                                                            @for (var estimateItemIndex = 0; estimateItemIndex < note.EstimateItems.Count; estimateItemIndex++)
                                                            {
                                                                var estimateItem = note.EstimateItems[estimateItemIndex];
                                                                var inputPrefix = $"{estimatePrefix}[{estimateItemIndex}]";
                                                                var estimateItemLocalId = $"estimate-item-{estimateItem.Id}";

                                                                <span data-estimate-item-inputs="@estimateItemLocalId">
                                                                    <input name="@(inputPrefix).Id" type="hidden" value="@estimateItem.Id" />
                                                                    <input data-estimate-name-input name="@(inputPrefix).Name" type="hidden" value="@estimateItem.Name" />
                                                                    <input data-estimate-cost-input="@note.Id" name="@(inputPrefix).Cost" type="hidden" value="@estimateItem.Cost" />
                                                                    <input data-estimate-hours-input="@note.Id" name="@(inputPrefix).Hours" type="hidden" value="@estimateItem.Hours" />
                                                                    <input name="@(inputPrefix).IsNew" type="hidden" value="@estimateItem.IsNew" />
                                                                </span>
                                                            }
                                                        </div>

                                                        <div class="fw-bold mb-2">Photos</div>
                                                        @if (note.Photos.Count == 0)
                                                        {
                                                            <p class="text-muted mb-0">No pictures found.</p>
                                                        }
                                                        else
                                                        {
                                                            <div class="d-flex flex-wrap gap-2">
                                                                @for (var photoIndex = 0; photoIndex < note.Photos.Count; photoIndex++)
                                                                {
                                                                    var photo = note.Photos[photoIndex];
                                                                    var croppedInputId = $"cropped-photo-{photo.Id}";
                                                                    var thumbnailImageId = $"thumbnail-photo-{photo.Id}";

                                                                    <input name="Buildings[@buildingIndex].Areas[@areaIndex].Notes[@noteIndex].Photos[@photoIndex].Id"
                                                                           type="hidden"
                                                                           value="@photo.Id" />
                                                                    <input id="@croppedInputId"
                                                                           name="Buildings[@buildingIndex].Areas[@areaIndex].Notes[@noteIndex].Photos[@photoIndex].CroppedDataUrl"
                                                                           type="hidden"
                                                                           value="@photo.CroppedDataUrl" />
                                                                    <button class="btn p-0 border-0"
                                                                            type="button"
                                                                            data-photo-src="@GetPhotoSource(photo)"
                                                                            data-photo-alt="@GetPhotoAlt(photo)"
                                                                            data-photo-file-name="@GetPhotoFileName(photo)"
                                                                            data-photo-size="@FormatBytes(photo.SizeBytes)"
                                                                            data-photo-dimensions="@FormatDimensions(photo)"
                                                                            data-photo-type="@photo.ImageType"
                                                                            data-cropped-input-id="@croppedInputId"
                                                                            data-thumbnail-image-id="@thumbnailImageId"
                                                                            data-bs-toggle="modal"
                                                                            data-bs-target="#inspectionPhotoModal">
                                                                        <img class="img-thumbnail"
                                                                             id="@thumbnailImageId"
                                                                             src="@GetPhotoSource(photo)"
                                                                             alt="@GetPhotoAlt(photo)"
                                                                             style="width: 192px; height: 144px; object-fit: contain;" />
                                                                    </button>
                                                                }
                                                            </div>
                                                        }
                                                    </section>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    }
                }
            </section>
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        @if (Model.Id.HasValue)
        {
            <a class="btn btn-secondary"
               asp-controller="Inspections"
               asp-action="@Model.CancelAction"
               asp-route-id="@Model.Id">
                Cancel
            </a>
        }
        else
        {
            <a class="btn btn-secondary"
               asp-controller="Inspections"
               asp-action="@Model.CancelAction">
                Cancel
            </a>
        }
        <button class="btn btn-primary" type="submit">Save</button>
    </div>
</form>

<partial name="_UnsavedChangesDialog" />

<div class="modal" id="customerMatchModal" tabindex="-1" aria-labelledby="customerMatchModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5" id="customerMatchModalLabel">Customer Match</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>The customer data you entered closely matches an existing customer.</p>

                <div class="d-grid gap-2 mb-3">
                    @foreach (var customer in Model.CustomerMatches)
                    {
                        <button class="btn btn-outline-secondary text-start p-3"
                                type="button"
                                data-customer-match-id="@customer.CustomerId"
                                data-customer-match-first-name="@customer.FirstName"
                                data-customer-match-last-name="@customer.LastName"
                                data-customer-match-company-name="@customer.CompanyName"
                                data-customer-match-phone="@customer.Phone"
                                data-customer-match-email="@customer.Email"
                                data-customer-match-street1="@customer.Street1"
                                data-customer-match-city="@customer.City"
                                data-customer-match-state="@customer.State"
                                data-customer-match-postal-code="@customer.PostalCode">
                            <div class="d-flex flex-wrap justify-content-between gap-3">
                                <strong>@string.Join(" ", new[] { customer.FirstName, customer.LastName }.Where(value => !string.IsNullOrWhiteSpace(value)))</strong>
                                <span>@customer.Phone</span>
                            </div>
                            <div>@customer.CompanyName</div>
                            <div class="small text-muted">@customer.Email</div>
                            <div class="small text-muted">
                                @string.Join(", ", new[] { customer.Street1, customer.City, customer.State, customer.PostalCode }
                                    .Where(value => !string.IsNullOrWhiteSpace(value)))
                            </div>
                        </button>
                    }
                </div>

                <p>If you want to use an existing customer, select that customer from the list.</p>
                <p class="mb-0">If you want to create a new Customer, click New Customer.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" id="customerMatchNewButton" type="button">New Customer</button>
            </div>
        </div>
    </div>
</div>

@{
    var customerPickerPreviousPage = Math.Max(1, Model.CustomerPicker.Page - 1);
    var customerPickerNextPage = Math.Min(Model.CustomerPicker.TotalPages, Model.CustomerPicker.Page + 1);
    var customerPickerRows = new[] { 5, 10, 15, 25, 50, 100 };
    var customerPickerAction = Model.Id.HasValue ? "EditFindCustomer" : "New";
}

<div class="modal fade" id="findCustomerModal" tabindex="-1" aria-labelledby="findCustomerModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-fullscreen">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="findCustomerModalLabel">Find Customer</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form asp-controller="Inspections"
                          asp-action="@customerPickerAction"
                          asp-route-id="@Model.Id"
                          class="mb-3"
                          id="findCustomerForm"
                          method="get">
                        <input name="showCustomerPicker" type="hidden" value="true" />
                        <input id="findCustomerPage" name="customerPage" type="hidden" value="@Model.CustomerPicker.Page" />

                        <div class="d-flex flex-wrap justify-content-end gap-2">
                            <input class="form-control"
                                   id="findCustomerSearch"
                                   name="customerSearch"
                                   placeholder="search customers"
                                   type="search"
                                   value="@Model.CustomerPicker.Search"
                                   style="max-width: 28rem;" />
                            <button class="btn btn-outline-secondary" id="findCustomerClearButton" type="button">Clear</button>
                        </div>

                        <div class="d-flex justify-content-end mt-3">
                            <label class="form-label d-flex align-items-center gap-2 mb-0" for="findCustomerRows">
                                Rows
                                <select class="form-select"
                                        id="findCustomerRows"
                                        name="customerRows"
                                        style="width: auto;">
                                    @foreach (var rows in customerPickerRows)
                                    {
                                        if (Model.CustomerPicker.PageSize == rows)
                                        {
                                            <option value="@rows" selected>@rows</option>
                                        }
                                        else
                                        {
                                            <option value="@rows">@rows</option>
                                        }
                                    }
                                </select>
                            </label>
                        </div>
                    </form>

                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle">
                            <thead>
                                <tr>
                                    <th scope="col">First Name</th>
                                    <th scope="col">Last Name</th>
                                    <th scope="col">Company</th>
                                    <th scope="col">Phone</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.CustomerPicker.Customers.Count == 0)
                                {
                                    <tr>
                                        <td class="text-muted" colspan="4">No customers found.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var customer in Model.CustomerPicker.Customers)
                                    {
                                        <tr class="clickable-table-row"
                                            data-customer-id="@customer.CustomerId"
                                            data-customer-first-name="@customer.FirstName"
                                            data-customer-last-name="@customer.LastName"
                                            data-customer-company-name="@customer.CompanyName"
                                            data-customer-phone="@customer.Phone"
                                            data-customer-email="@customer.Email"
                                            data-customer-street1="@customer.Street1"
                                            data-customer-street2="@customer.Street2"
                                            data-customer-city="@customer.City"
                                            data-customer-state="@customer.State"
                                            data-customer-postal-code="@customer.PostalCode"
                                            data-customer-notes="@customer.Notes"
                                            tabindex="0"
                                            aria-label="Select @string.Join(" ", new[] { customer.FirstName, customer.LastName }.Where(value => !string.IsNullOrWhiteSpace(value)))">
                                            <td>@customer.FirstName</td>
                                            <td>@customer.LastName</td>
                                            <td>@customer.CompanyName</td>
                                            <td>@customer.Phone</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex align-items-center justify-content-between gap-3">
                        <div class="btn-group" role="group" aria-label="Customer picker pages">
                            <a class="btn btn-outline-secondary @(Model.CustomerPicker.Page == 1 ? "disabled" : string.Empty)"
                               asp-controller="Inspections"
                               asp-action="@customerPickerAction"
                               asp-route-id="@Model.Id"
                               asp-route-customerSearch="@Model.CustomerPicker.Search"
                               asp-route-customerRows="@Model.CustomerPicker.PageSize"
                               asp-route-customerPage="1"
                               asp-route-showCustomerPicker="true">
                                First
                            </a>
                            <a class="btn btn-outline-secondary @(Model.CustomerPicker.Page == 1 ? "disabled" : string.Empty)"
                               asp-controller="Inspections"
                               asp-action="@customerPickerAction"
                               asp-route-id="@Model.Id"
                               asp-route-customerSearch="@Model.CustomerPicker.Search"
                               asp-route-customerRows="@Model.CustomerPicker.PageSize"
                               asp-route-customerPage="@customerPickerPreviousPage"
                               asp-route-showCustomerPicker="true">
                                Previous
                            </a>
                            <a class="btn btn-outline-secondary @(Model.CustomerPicker.Page == Model.CustomerPicker.TotalPages ? "disabled" : string.Empty)"
                               asp-controller="Inspections"
                               asp-action="@customerPickerAction"
                               asp-route-id="@Model.Id"
                               asp-route-customerSearch="@Model.CustomerPicker.Search"
                               asp-route-customerRows="@Model.CustomerPicker.PageSize"
                               asp-route-customerPage="@customerPickerNextPage"
                               asp-route-showCustomerPicker="true">
                                Next
                            </a>
                            <a class="btn btn-outline-secondary @(Model.CustomerPicker.Page == Model.CustomerPicker.TotalPages ? "disabled" : string.Empty)"
                               asp-controller="Inspections"
                               asp-action="@customerPickerAction"
                               asp-route-id="@Model.Id"
                               asp-route-customerSearch="@Model.CustomerPicker.Search"
                               asp-route-customerRows="@Model.CustomerPicker.PageSize"
                               asp-route-customerPage="@Model.CustomerPicker.TotalPages"
                               asp-route-showCustomerPicker="true">
                                Last
                            </a>
                        </div>
                        <span class="text-muted">Page @Model.CustomerPicker.Page of @Model.CustomerPicker.TotalPages</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

@if (!Model.Id.HasValue)
{
    <partial name="_SaveInspectionRequiredDialog" />
}

