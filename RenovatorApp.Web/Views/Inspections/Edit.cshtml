@functions {
    private static string FormatCurrency(decimal value)
    {
        return $"${value:N2}";
    }

    private static string FormatHours(decimal value)
    {
        return value.ToString("0.##");
    }

    private static string FormatBytes(long value)
    {
        return $"{value:N0} bytes";
    }

    private static string FormatDimensions(RenovatorApp.Web.ViewModels.InspectionAreaNotePhotoEditViewModel photo)
    {
        return photo.WidthPixels.HasValue && photo.HeightPixels.HasValue
            ? $"{photo.WidthPixels.Value} x {photo.HeightPixels.Value} px"
            : "Unknown";
    }

    private static string GetPhotoSource(RenovatorApp.Web.ViewModels.InspectionAreaNotePhotoEditViewModel photo)
    {
        var contentType = string.IsNullOrWhiteSpace(photo.ContentType) ? "image/jpeg" : photo.ContentType;

        return $"data:{contentType};base64,{Convert.ToBase64String(photo.Data)}";
    }

    private static string GetPhotoAlt(RenovatorApp.Web.ViewModels.InspectionAreaNotePhotoEditViewModel photo)
    {
        return string.IsNullOrWhiteSpace(photo.FileName) ? "Inspection note picture" : photo.FileName;
    }

    private static string GetPhotoFileName(RenovatorApp.Web.ViewModels.InspectionAreaNotePhotoEditViewModel photo)
    {
        return string.IsNullOrWhiteSpace(photo.FileName) ? "Unnamed picture" : photo.FileName;
    }
}

@section Scripts {
    <script>
        const inspectionIsSaved = @Model.Id.HasValue.ToString().ToLowerInvariant();
        const inspectionEditForm = document.getElementById('inspectionEditForm');
        const unsavedChangesModal = document.getElementById('unsavedChangesModal');
        const unsavedChangesYesButton = document.getElementById('unsavedChangesYesButton');
        const customerMatchModal = document.getElementById('customerMatchModal');
        const customerMatchNewButton = document.getElementById('customerMatchNewButton');
        const forceNewCustomerInput = document.getElementById('ForceNewCustomer');
        const showCustomerMatchDialog = @Model.ShowCustomerMatchDialog.ToString().ToLowerInvariant();
        let inspectionHasUnsavedChanges = false;
        let inspectionAllowNavigation = false;
        let pendingNavigationUrl = '';

        function markInspectionDirty() {
            inspectionHasUnsavedChanges = true;
        }

        function continuePendingNavigation() {
            if (!pendingNavigationUrl) {
                return;
            }

            inspectionAllowNavigation = true;
            window.location.href = pendingNavigationUrl;
        }

        function promptForUnsavedNavigation(url) {
            pendingNavigationUrl = url;

            if (unsavedChangesModal) {
                bootstrap.Modal.getOrCreateInstance(unsavedChangesModal).show();
            }
        }

        function showCustomerTab() {
            const customerTab = document.getElementById('customer-tab');

            if (customerTab) {
                bootstrap.Tab.getOrCreateInstance(customerTab).show();
            }
        }

        inspectionEditForm?.addEventListener('input', markInspectionDirty);
        inspectionEditForm?.addEventListener('change', markInspectionDirty);
        inspectionEditForm?.addEventListener('submit', () => {
            inspectionAllowNavigation = true;
            inspectionHasUnsavedChanges = false;
        });

        window.addEventListener('beforeunload', event => {
            if (!inspectionHasUnsavedChanges || inspectionAllowNavigation) {
                return;
            }

            event.preventDefault();
            event.returnValue = '';
        });

        unsavedChangesYesButton?.addEventListener('click', continuePendingNavigation);
        unsavedChangesModal?.addEventListener('hidden.bs.modal', () => {
            if (!inspectionAllowNavigation) {
                pendingNavigationUrl = '';
            }
        });

        document.querySelectorAll('a[href]').forEach(link => {
            link.addEventListener('click', event => {
                const href = link.getAttribute('href') || '';

                if (href.startsWith('#') || link.target === '_blank' || link.hasAttribute('download')) {
                    return;
                }

                if (inspectionHasUnsavedChanges && !inspectionAllowNavigation) {
                    event.preventDefault();
                    promptForUnsavedNavigation(link.href);
                }
            });
        });

        if (showCustomerMatchDialog && customerMatchModal) {
            showCustomerTab();
            bootstrap.Modal.getOrCreateInstance(customerMatchModal).show();
        }

        document.querySelectorAll('[data-customer-match-id]').forEach(button => {
            button.addEventListener('click', () => {
                showCustomerTab();
                setCustomerField('Customer_CustomerId', button.dataset.customerMatchId);
                setCustomerField('Customer_FirstName', button.dataset.customerMatchFirstName);
                setCustomerField('Customer_LastName', button.dataset.customerMatchLastName);
                setCustomerField('Customer_CompanyName', button.dataset.customerMatchCompanyName);
                setCustomerField('Customer_Phone', button.dataset.customerMatchPhone);
                setCustomerField('Customer_Email', button.dataset.customerMatchEmail);
                setCustomerField('Customer_Street1', button.dataset.customerMatchStreet1);
                setCustomerField('Customer_Street2', '');
                setCustomerField('Customer_City', button.dataset.customerMatchCity);
                setCustomerField('Customer_State', button.dataset.customerMatchState);
                setCustomerField('Customer_PostalCode', button.dataset.customerMatchPostalCode);

                if (forceNewCustomerInput) {
                    forceNewCustomerInput.value = 'false';
                }

                inspectionAllowNavigation = true;
                bootstrap.Modal.getOrCreateInstance(customerMatchModal).hide();
                inspectionEditForm?.submit();
            });
        });

        customerMatchNewButton?.addEventListener('click', () => {
            setCustomerField('Customer_CustomerId', '');

            if (forceNewCustomerInput) {
                forceNewCustomerInput.value = 'true';
            }

            inspectionAllowNavigation = true;
            inspectionEditForm?.submit();
        });

        if (!inspectionIsSaved) {
            document.querySelectorAll('#customer-tab, #property-tab, #buildings-tab').forEach(tab => {
                tab.addEventListener('show.bs.tab', event => {
                    event.preventDefault();
                    const saveInspectionRequiredModal = document.getElementById('saveInspectionRequiredModal');

                    if (saveInspectionRequiredModal) {
                        bootstrap.Modal.getOrCreateInstance(saveInspectionRequiredModal).show();
                    }
                });
            });
        }

        document.querySelectorAll('[data-building-target]').forEach(button => {
            button.addEventListener('click', () => {
                const target = button.dataset.buildingTarget;
                const section = button.closest('.detail-section');

                section.querySelectorAll('[data-building-target]').forEach(item => {
                    const isSelected = item === button;
                    item.classList.toggle('btn-primary', isSelected);
                    item.classList.toggle('btn-outline-primary', !isSelected);
                    item.setAttribute('aria-pressed', isSelected.toString());
                });

                section.querySelectorAll('[data-building-panel]').forEach(panel => {
                    panel.classList.toggle('d-none', panel.dataset.buildingPanel !== target);
                });
            });
        });

        document.querySelectorAll('[data-area-target]').forEach(button => {
            button.addEventListener('click', () => {
                const target = button.dataset.areaTarget;
                const buildingPanel = button.closest('[data-building-panel]');

                buildingPanel.querySelectorAll('[data-area-target]').forEach(item => {
                    const isSelected = item === button;
                    item.classList.toggle('btn-secondary', isSelected);
                    item.classList.toggle('btn-outline-secondary', !isSelected);
                    item.setAttribute('aria-pressed', isSelected.toString());
                });

                buildingPanel.querySelectorAll('[data-area-panel]').forEach(panel => {
                    panel.classList.toggle('d-none', panel.dataset.areaPanel !== target);
                });
            });
        });

        const inspectorPickerModal = document.getElementById('inspectorPickerModal');
        const inspectorNameInput = document.getElementById('InspectorName');
        const findCustomerModal = document.getElementById('findCustomerModal');
        const findCustomerForm = document.getElementById('findCustomerForm');
        const findCustomerSearch = document.getElementById('findCustomerSearch');
        const findCustomerClearButton = document.getElementById('findCustomerClearButton');
        const findCustomerRows = document.getElementById('findCustomerRows');
        const findCustomerPage = document.getElementById('findCustomerPage');
        const openFindCustomerOnLoad = @Model.CustomerPicker.OpenOnLoad.ToString().ToLowerInvariant();
        let findCustomerSearchTimer;

        document.querySelectorAll('[data-inspector-name]').forEach(button => {
            button.addEventListener('click', () => {
                if (inspectorNameInput) {
                    inspectorNameInput.value = button.dataset.inspectorName || '';
                    markInspectionDirty();
                }

                bootstrap.Modal.getOrCreateInstance(inspectorPickerModal).hide();
            });
        });

        if (openFindCustomerOnLoad && findCustomerModal) {
            showCustomerTab();
            bootstrap.Modal.getOrCreateInstance(findCustomerModal).show();
        }

        findCustomerSearch?.addEventListener('input', () => {
            window.clearTimeout(findCustomerSearchTimer);
            findCustomerSearchTimer = window.setTimeout(() => {
                if (findCustomerPage) {
                    findCustomerPage.value = '1';
                }

                findCustomerForm?.submit();
            }, 350);
        });

        findCustomerClearButton?.addEventListener('click', () => {
            if (findCustomerSearch) {
                findCustomerSearch.value = '';
            }

            if (findCustomerPage) {
                findCustomerPage.value = '1';
            }

            findCustomerForm?.submit();
        });

        findCustomerRows?.addEventListener('change', () => {
            if (findCustomerPage) {
                findCustomerPage.value = '1';
            }

            findCustomerForm?.submit();
        });

        function setCustomerField(id, value) {
            const input = document.getElementById(id);

            if (input) {
                input.value = value || '';
            }
        }

        document.querySelectorAll('[data-customer-id]').forEach(row => {
            const selectCustomer = () => {
                showCustomerTab();
                setCustomerField('Customer_CustomerId', row.dataset.customerId);
                setCustomerField('Customer_FirstName', row.dataset.customerFirstName);
                setCustomerField('Customer_LastName', row.dataset.customerLastName);
                setCustomerField('Customer_CompanyName', row.dataset.customerCompanyName);
                setCustomerField('Customer_Phone', row.dataset.customerPhone);
                setCustomerField('Customer_Email', row.dataset.customerEmail);
                setCustomerField('Customer_Street1', row.dataset.customerStreet1);
                setCustomerField('Customer_Street2', row.dataset.customerStreet2);
                setCustomerField('Customer_City', row.dataset.customerCity);
                setCustomerField('Customer_State', row.dataset.customerState);
                setCustomerField('Customer_PostalCode', row.dataset.customerPostalCode);
                setCustomerField('Customer_Notes', row.dataset.customerNotes);
                if (forceNewCustomerInput) {
                    forceNewCustomerInput.value = 'false';
                }
                markInspectionDirty();

                if (findCustomerModal) {
                    bootstrap.Modal.getOrCreateInstance(findCustomerModal).hide();
                }
            };

            row.addEventListener('click', selectCustomer);
            row.addEventListener('keydown', event => {
                if (event.key === 'Enter' || event.key === ' ') {
                    event.preventDefault();
                    selectCustomer();
                }
            });
        });

        const addPartModal = document.getElementById('addPartModal');
        const addPartForm = document.getElementById('addPartForm');
        const addPartName = document.getElementById('addPartName');
        const addPartCost = document.getElementById('addPartCost');
        const addPartHours = document.getElementById('addPartHours');
        const findPartButton = document.getElementById('findPartButton');
        const findPartModal = document.getElementById('findPartModal');
        const findPartSearch = document.getElementById('findPartSearch');
        const findPartClearButton = document.getElementById('findPartClearButton');
        const findPartResults = document.getElementById('findPartResults');
        const findPartPrompt = document.getElementById('findPartPrompt');
        const findPartEmpty = document.getElementById('findPartEmpty');
        const deletePartModal = document.getElementById('deletePartModal');
        const confirmDeletePartButton = document.getElementById('confirmDeletePartButton');
        const editPartModal = document.getElementById('editPartModal');
        const editPartForm = document.getElementById('editPartForm');
        const editPartName = document.getElementById('editPartName');
        const editPartCost = document.getElementById('editPartCost');
        const editPartHours = document.getElementById('editPartHours');
        let activeAddPartButton = null;
        let activeDeletePartButton = null;
        let activeEditPartButton = null;

        function formatCurrencyValue(value) {
            return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(value);
        }

        function formatHoursValue(value) {
            return Number.isInteger(value) ? value.toString() : value.toFixed(2).replace(/0+$/, '').replace(/\.$/, '');
        }

        function createHiddenInput(name, value) {
            const input = document.createElement('input');

            input.type = 'hidden';
            input.name = name;
            input.value = value;

            return input;
        }

        function createLocalId() {
            return crypto.randomUUID
                ? crypto.randomUUID()
                : `new-${Date.now()}-${Math.random().toString(16).slice(2)}`;
        }

        function recalculateEstimateTotals(noteId) {
            let totalCost = 0;
            let totalHours = 0;

            document.querySelectorAll(`[data-estimate-cost-input="${noteId}"]`).forEach(input => {
                totalCost += Number.parseFloat(input.value) || 0;
            });
            document.querySelectorAll(`[data-estimate-hours-input="${noteId}"]`).forEach(input => {
                totalHours += Number.parseFloat(input.value) || 0;
            });

            const totalCostElement = document.querySelector(`[data-estimate-total-cost="${noteId}"]`);
            const totalHoursElement = document.querySelector(`[data-estimate-total-hours="${noteId}"]`);

            if (totalCostElement) {
                totalCostElement.textContent = formatCurrencyValue(totalCost);
            }

            if (totalHoursElement) {
                totalHoursElement.textContent = formatHoursValue(totalHours);
            }
        }

        function updateEstimateEmptyState(tableContainer, emptyMessage) {
            const hasRows = (tableContainer?.querySelectorAll('tbody tr').length || 0) > 0;

            tableContainer?.classList.toggle('d-none', !hasRows);
            emptyMessage?.classList.toggle('d-none', hasRows);
            emptyMessage?.classList.toggle('mb-3', !hasRows);
        }

        addPartModal?.addEventListener('show.bs.modal', event => {
            activeAddPartButton = event.relatedTarget;
            addPartForm?.reset();
        });

        addPartForm?.addEventListener('submit', event => {
            event.preventDefault();

            if (!activeAddPartButton) {
                return;
            }

            const noteId = activeAddPartButton.dataset.addPartNoteId;
            const tableContainer = document.getElementById(activeAddPartButton.dataset.addPartTableId || '');
            const tableBody = tableContainer?.querySelector('tbody');
            const emptyMessage = document.getElementById(activeAddPartButton.dataset.addPartEmptyId || '');
            const inputsContainer = document.getElementById(activeAddPartButton.dataset.addPartInputsId || '');
            const prefix = activeAddPartButton.dataset.addPartPrefix;
            const nextIndex = Number.parseInt(activeAddPartButton.dataset.addPartNextIndex || '0', 10);
            const name = addPartName.value.trim();
            const cost = Number.parseFloat(addPartCost.value) || 0;
            const hours = Number.parseFloat(addPartHours.value) || 0;

            if (!name || !tableBody || !inputsContainer || !prefix || !noteId) {
                return;
            }

            const estimateItemLocalId = `estimate-item-${createLocalId()}`;
            const row = document.createElement('tr');
            row.dataset.estimateItemRow = estimateItemLocalId;
            row.innerHTML = `
                <td data-estimate-item-name>${name}</td>
                <td class="text-end" data-estimate-item-cost>${formatCurrencyValue(cost)}</td>
                <td class="text-end" data-estimate-item-hours>${formatHoursValue(hours)}</td>
                <td class="text-end">
                    <div class="d-inline-flex gap-1">
                        <button class="btn btn-sm btn-success"
                                type="button"
                                data-edit-estimate-item-id="${estimateItemLocalId}"
                                data-edit-estimate-note-id="${noteId}"
                                aria-label="Edit estimate item">
                            <svg aria-hidden="true" fill="none" height="14" viewBox="0 0 24 24" width="14" xmlns="http://www.w3.org/2000/svg">
                                <path d="M12 20h9" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
                                <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
                            </svg>
                        </button>
                        <button class="btn btn-sm btn-danger"
                                type="button"
                                data-delete-estimate-item-id="${estimateItemLocalId}"
                                data-delete-estimate-note-id="${noteId}"
                                data-delete-estimate-table-id="${activeAddPartButton.dataset.addPartTableId || ''}"
                                data-delete-estimate-empty-id="${activeAddPartButton.dataset.addPartEmptyId || ''}"
                                aria-label="Delete estimate item">
                            <svg aria-hidden="true" fill="none" height="14" viewBox="0 0 24 24" width="14" xmlns="http://www.w3.org/2000/svg">
                                <path d="M3 6h18" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
                                <path d="M8 6V4h8v2" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
                                <path d="M19 6 18 20H6L5 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
                                <path d="M10 11v5M14 11v5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" />
                            </svg>
                        </button>
                    </div>
                </td>`;
            tableBody.appendChild(row);

            const inputPrefix = `${prefix}[${nextIndex}]`;
            const costInput = createHiddenInput(`${inputPrefix}.Cost`, cost.toString());
            const hoursInput = createHiddenInput(`${inputPrefix}.Hours`, hours.toString());
            costInput.dataset.estimateCostInput = noteId;
            hoursInput.dataset.estimateHoursInput = noteId;

            const inputGroup = document.createElement('span');
            inputGroup.dataset.estimateItemInputs = estimateItemLocalId;
            inputGroup.appendChild(createHiddenInput(`${inputPrefix}.Id`, createLocalId()));
            const nameInput = createHiddenInput(`${inputPrefix}.Name`, name);
            nameInput.dataset.estimateNameInput = '';
            inputGroup.appendChild(nameInput);
            inputGroup.appendChild(costInput);
            inputGroup.appendChild(hoursInput);
            inputGroup.appendChild(createHiddenInput(`${inputPrefix}.IsNew`, 'true'));
            inputsContainer.appendChild(inputGroup);

            activeAddPartButton.dataset.addPartNextIndex = (nextIndex + 1).toString();
            emptyMessage?.classList.add('d-none');
            tableContainer?.classList.remove('d-none');
            recalculateEstimateTotals(noteId);
            markInspectionDirty();
            bootstrap.Modal.getOrCreateInstance(addPartModal).hide();
        });

        findPartButton?.addEventListener('click', () => {
            bootstrap.Modal.getOrCreateInstance(findPartModal).show();
        });

        function filterFindPartResults() {
            const searchValue = (findPartSearch?.value || '').trim().toLowerCase();
            let matchCount = 0;

            if (searchValue.length < 2) {
                findPartResults?.classList.add('d-none');
                findPartPrompt?.classList.remove('d-none');
                findPartEmpty?.classList.add('d-none');
                document.querySelectorAll('[data-find-part-item]').forEach(item => item.classList.add('d-none'));
                return;
            }

            document.querySelectorAll('[data-find-part-item]').forEach(item => {
                const isMatch = (item.dataset.partSearch || '').toLowerCase().includes(searchValue);

                item.classList.toggle('d-none', !isMatch);

                if (isMatch) {
                    matchCount++;
                }
            });

            findPartResults?.classList.toggle('d-none', matchCount === 0);
            findPartPrompt?.classList.add('d-none');
            findPartEmpty?.classList.toggle('d-none', matchCount > 0);
        }

        findPartModal?.addEventListener('shown.bs.modal', () => {
            findPartSearch?.focus();
            filterFindPartResults();
        });

        findPartModal?.addEventListener('hidden.bs.modal', () => {
            if (addPartModal?.classList.contains('show')) {
                document.body.classList.add('modal-open');
            }
        });

        findPartSearch?.addEventListener('input', filterFindPartResults);

        findPartClearButton?.addEventListener('click', () => {
            findPartSearch.value = '';
            findPartSearch.focus();
            filterFindPartResults();
        });

        document.querySelectorAll('[data-find-part-item]').forEach(button => {
            button.addEventListener('click', () => {
                addPartName.value = button.dataset.partName || '';
                addPartCost.value = button.dataset.partCost || '';
                bootstrap.Modal.getOrCreateInstance(findPartModal).hide();
            });
        });

        document.addEventListener('click', event => {
            const deleteButton = event.target.closest('[data-delete-estimate-item-id]');

            if (!deleteButton) {
                return;
            }

            activeDeletePartButton = deleteButton;
            bootstrap.Modal.getOrCreateInstance(deletePartModal).show();
        });

        confirmDeletePartButton?.addEventListener('click', () => {
            if (!activeDeletePartButton) {
                return;
            }

            const estimateItemId = activeDeletePartButton.dataset.deleteEstimateItemId;
            const noteId = activeDeletePartButton.dataset.deleteEstimateNoteId;
            const tableContainer = document.getElementById(activeDeletePartButton.dataset.deleteEstimateTableId || '');
            const emptyMessage = document.getElementById(activeDeletePartButton.dataset.deleteEstimateEmptyId || '');

            document.querySelector(`[data-estimate-item-row="${estimateItemId}"]`)?.remove();
            document.querySelector(`[data-estimate-item-inputs="${estimateItemId}"]`)?.remove();

            if (noteId) {
                recalculateEstimateTotals(noteId);
            }

            updateEstimateEmptyState(tableContainer, emptyMessage);
            markInspectionDirty();
            bootstrap.Modal.getOrCreateInstance(deletePartModal).hide();
            activeDeletePartButton = null;
        });

        document.addEventListener('click', event => {
            const editButton = event.target.closest('[data-edit-estimate-item-id]');

            if (!editButton) {
                return;
            }

            const estimateItemId = editButton.dataset.editEstimateItemId;
            const inputGroup = document.querySelector(`[data-estimate-item-inputs="${estimateItemId}"]`);

            activeEditPartButton = editButton;
            editPartName.value = inputGroup?.querySelector('[data-estimate-name-input]')?.value || '';
            editPartCost.value = inputGroup?.querySelector('[data-estimate-cost-input]')?.value || '';
            editPartHours.value = inputGroup?.querySelector('[data-estimate-hours-input]')?.value || '';
            bootstrap.Modal.getOrCreateInstance(editPartModal).show();
        });

        editPartForm?.addEventListener('submit', event => {
            event.preventDefault();

            if (!activeEditPartButton) {
                return;
            }

            const estimateItemId = activeEditPartButton.dataset.editEstimateItemId;
            const noteId = activeEditPartButton.dataset.editEstimateNoteId;
            const row = document.querySelector(`[data-estimate-item-row="${estimateItemId}"]`);
            const inputGroup = document.querySelector(`[data-estimate-item-inputs="${estimateItemId}"]`);
            const name = editPartName.value.trim();
            const cost = Number.parseFloat(editPartCost.value) || 0;
            const hours = Number.parseFloat(editPartHours.value) || 0;

            if (!name || !row || !inputGroup || !noteId) {
                return;
            }

            row.querySelector('[data-estimate-item-name]').textContent = name;
            row.querySelector('[data-estimate-item-cost]').textContent = formatCurrencyValue(cost);
            row.querySelector('[data-estimate-item-hours]').textContent = formatHoursValue(hours);
            inputGroup.querySelector('[data-estimate-name-input]').value = name;
            inputGroup.querySelector('[data-estimate-cost-input]').value = cost.toString();
            inputGroup.querySelector('[data-estimate-hours-input]').value = hours.toString();
            recalculateEstimateTotals(noteId);
            markInspectionDirty();
            bootstrap.Modal.getOrCreateInstance(editPartModal).hide();
            activeEditPartButton = null;
        });

        const photoModal = document.getElementById('inspectionPhotoModal');
        const photoModalImage = document.getElementById('inspectionPhotoModalImage');
        const photoCropSurface = document.getElementById('inspectionPhotoCropSurface');
        const photoCropBox = document.getElementById('inspectionPhotoCropBox');
        const photoRestoreButton = document.getElementById('inspectionPhotoRestoreButton');
        const photoSaveButton = document.getElementById('inspectionPhotoSaveButton');
        const photoModalFileName = document.getElementById('inspectionPhotoModalFileName');
        const photoModalSize = document.getElementById('inspectionPhotoModalSize');
        const photoModalDimensions = document.getElementById('inspectionPhotoModalDimensions');
        const photoModalType = document.getElementById('inspectionPhotoModalType');
        let activePhotoButton = null;
        let activeCroppedInput = null;
        let activeThumbnailImage = null;
        let activeOriginalPhotoSrc = '';
        let cropStart = null;
        let cropSelection = null;

        function resetCropSelection() {
            cropStart = null;
            cropSelection = null;
            photoCropBox?.classList.add('d-none');

            if (photoCropBox) {
                photoCropBox.style.left = '0';
                photoCropBox.style.top = '0';
                photoCropBox.style.width = '0';
                photoCropBox.style.height = '0';
            }
        }

        function getSurfacePoint(event) {
            const surfaceRect = photoCropSurface.getBoundingClientRect();

            return {
                x: Math.max(0, Math.min(event.clientX - surfaceRect.left, surfaceRect.width)),
                y: Math.max(0, Math.min(event.clientY - surfaceRect.top, surfaceRect.height))
            };
        }

        function getRenderedImageRect() {
            const elementRect = photoModalImage.getBoundingClientRect();
            const surfaceRect = photoCropSurface.getBoundingClientRect();
            const naturalWidth = photoModalImage.naturalWidth;
            const naturalHeight = photoModalImage.naturalHeight;

            if (!naturalWidth || !naturalHeight || !elementRect.width || !elementRect.height) {
                return {
                    left: elementRect.left - surfaceRect.left,
                    top: elementRect.top - surfaceRect.top,
                    width: elementRect.width,
                    height: elementRect.height
                };
            }

            const imageRatio = naturalWidth / naturalHeight;
            const elementRatio = elementRect.width / elementRect.height;
            let renderedWidth = elementRect.width;
            let renderedHeight = elementRect.height;

            if (imageRatio > elementRatio) {
                renderedHeight = elementRect.width / imageRatio;
            } else {
                renderedWidth = elementRect.height * imageRatio;
            }

            return {
                left: elementRect.left - surfaceRect.left + (elementRect.width - renderedWidth) / 2,
                top: elementRect.top - surfaceRect.top + (elementRect.height - renderedHeight) / 2,
                width: renderedWidth,
                height: renderedHeight
            };
        }

        function updateCropSelection(point) {
            const imageRect = getRenderedImageRect();
            const imageLeft = imageRect.left;
            const imageTop = imageRect.top;
            const imageRight = imageLeft + imageRect.width;
            const imageBottom = imageTop + imageRect.height;
            const startX = Math.max(imageLeft, Math.min(cropStart.x, imageRight));
            const startY = Math.max(imageTop, Math.min(cropStart.y, imageBottom));
            const endX = Math.max(imageLeft, Math.min(point.x, imageRight));
            const endY = Math.max(imageTop, Math.min(point.y, imageBottom));
            const left = Math.min(startX, endX);
            const top = Math.min(startY, endY);
            const width = Math.abs(endX - startX);
            const height = Math.abs(endY - startY);

            cropSelection = { left, top, width, height, imageLeft, imageTop, imageWidth: imageRect.width, imageHeight: imageRect.height };

            if (photoCropBox) {
                photoCropBox.style.left = `${left}px`;
                photoCropBox.style.top = `${top}px`;
                photoCropBox.style.width = `${width}px`;
                photoCropBox.style.height = `${height}px`;
                photoCropBox.classList.toggle('d-none', width < 4 || height < 4);
            }
        }

        function getCroppedPhotoDataUrl() {
            if (!cropSelection || cropSelection.width < 4 || cropSelection.height < 4 || !photoModalImage.naturalWidth || !photoModalImage.naturalHeight) {
                return photoModalImage.src || '';
            }

            const scaleX = photoModalImage.naturalWidth / cropSelection.imageWidth;
            const scaleY = photoModalImage.naturalHeight / cropSelection.imageHeight;
            const sourceX = Math.max(0, Math.round((cropSelection.left - cropSelection.imageLeft) * scaleX));
            const sourceY = Math.max(0, Math.round((cropSelection.top - cropSelection.imageTop) * scaleY));
            const sourceWidth = Math.max(1, Math.round(cropSelection.width * scaleX));
            const sourceHeight = Math.max(1, Math.round(cropSelection.height * scaleY));
            const canvas = document.createElement('canvas');
            const context = canvas.getContext('2d');

            canvas.width = sourceWidth;
            canvas.height = sourceHeight;
            context.drawImage(photoModalImage, sourceX, sourceY, sourceWidth, sourceHeight, 0, 0, sourceWidth, sourceHeight);

            return canvas.toDataURL('image/png');
        }

        function getDataUrlSizeBytes(dataUrl) {
            const base64 = dataUrl.split(',')[1] || '';
            const padding = base64.endsWith('==') ? 2 : base64.endsWith('=') ? 1 : 0;

            return Math.max(0, Math.floor(base64.length * 3 / 4) - padding);
        }

        function formatBytes(value) {
            return `${value.toLocaleString()} bytes`;
        }

        function updateModalMetadataFromImage(dataUrl) {
            photoModalSize.textContent = formatBytes(getDataUrlSizeBytes(dataUrl));
            photoModalDimensions.textContent = `${photoModalImage.naturalWidth} x ${photoModalImage.naturalHeight} px`;
            photoModalType.textContent = dataUrl.startsWith('data:image/png') ? 'png' : photoModalType.textContent;
        }

        photoModal?.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;

            if (!button || !photoModalImage) {
                return;
            }

            activePhotoButton = button;
            activeOriginalPhotoSrc = button.dataset.photoSrc || '';
            activeCroppedInput = document.getElementById(button.dataset.croppedInputId || '');
            activeThumbnailImage = document.getElementById(button.dataset.thumbnailImageId || '');
            resetCropSelection();

            photoModalImage.src = activeCroppedInput?.value || activeOriginalPhotoSrc;
            photoModalImage.alt = button.dataset.photoAlt || '';
            photoModalFileName.textContent = button.dataset.photoFileName || '';
            photoModalSize.textContent = button.dataset.photoSize || '';
            photoModalDimensions.textContent = button.dataset.photoDimensions || '';
            photoModalType.textContent = button.dataset.photoType || '';
        });

        photoModal?.addEventListener('hidden.bs.modal', () => {
            if (!photoModalImage) {
                return;
            }

            photoModalImage.src = '';
            photoModalImage.alt = '';
            photoModalFileName.textContent = '';
            photoModalSize.textContent = '';
            photoModalDimensions.textContent = '';
            photoModalType.textContent = '';
            activePhotoButton = null;
            activeCroppedInput = null;
            activeThumbnailImage = null;
            activeOriginalPhotoSrc = '';
            resetCropSelection();
        });

        photoCropSurface?.addEventListener('pointerdown', event => {
            if (!photoModalImage.src) {
                return;
            }

            cropStart = getSurfacePoint(event);
            updateCropSelection(cropStart);
            photoCropSurface.setPointerCapture(event.pointerId);
        });

        photoCropSurface?.addEventListener('pointermove', event => {
            if (!cropStart) {
                return;
            }

            updateCropSelection(getSurfacePoint(event));
        });

        photoCropSurface?.addEventListener('pointerup', event => {
            if (!cropStart) {
                return;
            }

            updateCropSelection(getSurfacePoint(event));
            cropStart = null;
            photoCropSurface.releasePointerCapture(event.pointerId);
        });

        photoSaveButton?.addEventListener('click', () => {
            if (!activeCroppedInput || !activeThumbnailImage || !photoModalImage.src) {
                return;
            }

            const croppedDataUrl = getCroppedPhotoDataUrl();

            activeCroppedInput.value = croppedDataUrl;
            activeThumbnailImage.src = croppedDataUrl;
            resetCropSelection();
            photoModalImage.addEventListener('load', () => updateModalMetadataFromImage(croppedDataUrl), { once: true });
            photoModalImage.src = croppedDataUrl;
            markInspectionDirty();
            bootstrap.Modal.getOrCreateInstance(photoModal).hide();
        });

        photoRestoreButton?.addEventListener('click', () => {
            if (!activeOriginalPhotoSrc) {
                return;
            }

            if (activeCroppedInput) {
                activeCroppedInput.value = '';
            }

            if (activeThumbnailImage) {
                activeThumbnailImage.src = activeOriginalPhotoSrc;
            }

            photoModalImage.src = activeOriginalPhotoSrc;
            resetCropSelection();
            markInspectionDirty();

            if (activePhotoButton) {
                photoModalSize.textContent = activePhotoButton.dataset.photoSize || '';
                photoModalDimensions.textContent = activePhotoButton.dataset.photoDimensions || '';
                photoModalType.textContent = activePhotoButton.dataset.photoType || '';
            }
        });
    </script>
}


