@{
    ViewData["Title"] = "RenovatorApp";
}

<div class="home-link-grid">
    <a class="app-hero app-hero-link" asp-controller="Inspections" asp-action="Index">
        <div>
            <h1>Inspections</h1>
            <p>Browse inspection data synced from RenovatorMaui.</p>
        </div>
    </a>

    <a class="app-hero app-hero-link" asp-controller="Customers" asp-action="Index">
        <div>
            <h1>Customers</h1>
            <p>Browse customer data synced from QuickBooks.</p>
        </div>
    </a>

    <a class="app-hero app-hero-link" asp-controller="Documents" asp-action="Index">
        <div>
            <h1>Documents</h1>
            <p>Browse customer documents and inspection reports.</p>
        </div>
    </a>

    <a class="app-hero app-hero-link" asp-controller="Employees" asp-action="Index">
        <div>
            <h1>Employees</h1>
            <p>Browse employee data synced from QuickBooks.</p>
        </div>
    </a>

    <a class="app-hero app-hero-link" asp-controller="Settings" asp-action="Index">
        <div>
            <h1>Settings</h1>
            <p>Manage parts and application settings.</p>
        </div>
    </a>
</div>
