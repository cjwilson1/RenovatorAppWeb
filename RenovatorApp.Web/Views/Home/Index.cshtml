@{
    ViewData["Title"] = "RenovatorApp";
}

<div class="home-link-grid">
    <a class="app-hero app-hero-link" asp-controller="Inspections" asp-action="Index">
        <div>
            <h1>Inspections</h1>
            <p>Browse inspection data synced from RenovatorMaui.</p>
        </div>
    </a>

    <a class="app-hero app-hero-link" asp-controller="Calendar" asp-action="Index">
        <div>
            <h1>Calendar</h1>
            <p>Manage calendar events, appointments, etc.</p>
        </div>
    </a>

    <a class="app-hero app-hero-link" asp-controller="Customers" asp-action="Index">
        <div>
            <h1>Customers</h1>
            <p>Manage customer data.</p>
        </div>
    </a>

    <a class="app-hero app-hero-link" asp-controller="Documents" asp-action="Index">
        <div>
            <h1>Documents</h1>
            <p>Browse customer documents and inspection reports.</p>
        </div>
    </a>

    <a class="app-hero app-hero-link" asp-controller="Properties" asp-action="Index">
        <div>
            <h1>Properties</h1>
            <p>Browse all properties.</p>
        </div>
    </a>

    <a class="app-hero app-hero-link" asp-controller="MileageTracking" asp-action="Index">
        <div>
            <h1>Mileage Tracking</h1>
            <p>Manage mileage trips</p>
        </div>
    </a>

    @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
    {
        <a class="app-hero app-hero-link" asp-controller="Employees" asp-action="Index">
            <div>
                <h1>Employees</h1>
                <p>Manage employee data.</p>
            </div>
        </a>

        <a class="app-hero app-hero-link" asp-controller="Settings" asp-action="Index">
            <div>
                <h1>Settings</h1>
                <p>Manage parts and application settings.</p>
            </div>
        </a>
    }
</div>
